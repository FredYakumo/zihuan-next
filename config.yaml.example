# =============================================================================
# zihuan-next configuration
# Copy this file to `config.yaml` and edit the values you need.
#
# This file is consumed only by the Python Alembic migrations
# (`utils/config_loader.py`) when running `alembic upgrade head` to create or
# migrate the message-store schema.
#
# At runtime the Rust binary does NOT read this file. Bot, Redis and database
# connections are configured per-graph through node input ports
# (BotAdapterNode, RedisNode, MySqlNode), or via environment variables such as
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/dbname
# =============================================================================

# MySQL configuration used by Alembic to build the SQLAlchemy URL.
MYSQL_HOST: 127.0.0.1
MYSQL_PORT: 3306
MYSQL_USER: zihuan
MYSQL_PASSWORD: your_mysql_password
MYSQL_DATABASE: zihuan_database
