import { LogEntryVm } from "../types.slint";
import { CjkText } from "buttons.slint";

export component LogOverlay {
    in property <[LogEntryVm]> entries;

    private property <length> row-height: 28px;
    private property <length> badge-width: 46px;
    private property <length> badge-height: 18px;
    private property <length> row-padding: 5px;

    // Width is set by the parent; height expands with content
    preferred-height: entries-layout.preferred-height;

    entries-layout := VerticalLayout {
        spacing: 4px;
        alignment: end;

        for entry in root.entries: Rectangle {
            height: root.row-height;
            border-radius: 4px;
            background: #000000bb;

            HorizontalLayout {
                padding: root.row-padding;
                spacing: 6px;
                alignment: start;

                // Level badge
                Rectangle {
                    width: root.badge-width;
                    height: root.badge-height;
                    y: (parent.height - self.height) / 2;
                    border-radius: 3px;
                    background:
                        entry.level == "ERROR" ? #f44336 :
                        entry.level == "WARN"  ? #ffc107 :
                        entry.level == "INFO"  ? #4caf50 :
                        entry.level == "DEBUG" ? #2196f3 :
                        /* TRACE */               #9e9e9e;

                    CjkText {
                        text: entry.level;
                        color:
                            entry.level == "WARN" ? #000000 : #ffffff;
                        font-size: 10px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }
                }

                // Message text
                CjkText {
                    text: entry.message;
                    color: #f0f0f0;
                    font-size: 12px;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    height: root.row-height;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
        }
    }
}
