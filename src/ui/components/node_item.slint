import { VerticalBox, ScrollView, LineEdit, CheckBox, ComboBox } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { MessageItemVm, PortVm } from "../types.slint";
import { CjkText } from "buttons.slint";

export component NodeItem inherits Rectangle {
    in property <string> node_id;
    in property <string> label;
    in property <string> preview_text;
    in property <string> node_type;
    in property <string> string_data_text;
    in property <string> message_event_filter_type;
    in property <[MessageItemVm]> message_list;
    in property <string> set_variable_name;
    in property <[string]> set_variable_options;
    in property <float> x_pos;
    in property <float> y_pos;
    in-out property <float> node_width;
    in-out property <float> node_height;
    in property <[PortVm]> input_ports;
    in property <[PortVm]> output_ports;
    in property <float> grid_size;
    in property <float> node_width_cells;
    in property <float> header_rows;
    in property <float> min_rows;
    in property <bool> is_selected;
    in property <bool> has_error;
    in property <bool> has_cycle;
    in property <bool> is_running: false;

    callback node_pointer_down(string, bool);
    callback node_moved(float, float);
    callback node_move_finished(float, float);
    callback port_clicked(string, string, bool);
    callback node_clicked(string, bool);
    callback node_right_clicked(string, float, float);
    callback inline_port_text_changed(string, string, string);
    callback inline_port_bool_changed(string, string, bool);
    callback message_list_add(string);
    callback message_list_insert(string, int);
    callback message_list_delete(string, int);
    callback message_list_move_up(string, int);
    callback message_list_move_down(string, int);
    callback message_list_cycle_role(string, int);
    callback message_list_set_content(string, int, string);
    callback qq_message_list_add(string);
    callback qq_message_list_insert(string, int);
    callback qq_message_list_cycle_type(string, int);
    callback qq_message_list_set_content(string, int, string);
    callback node_resized(float, float);
    callback node_resize_finished(float, float);
    callback show_help(string, string);
    callback port_right_clicked(string, string, float, float);
    callback edit_tools_clicked(string);
    callback edit_function_clicked(string);
    callback enter_function_subgraph_clicked(string);
    callback edit_format_string_clicked(string);
    callback edit_json_extract_clicked(string);
    callback set_variable_node_selected(string, string);

    property <int> spin-frame: 0;

    // Pure position helpers: frame 0-9 = top edge, 10-19 = right, 20-29 = bottom (rtl), 30-39 = left (btt)
    pure function perim-cx(f: float, nw: float) -> float {
        f < 10.0 ? f * nw / 10.0 :
        (f < 20.0 ? nw :
        (f < 30.0 ? (30.0 - f) * nw / 10.0 :
        0.0))
    }
    pure function perim-cy(f: float, nh: float) -> float {
        f < 10.0 ? 0.0 :
        (f < 20.0 ? (f - 10.0) * nh / 10.0 :
        (f < 30.0 ? nh :
        (40.0 - f) * nh / 10.0))
    }

    Timer {
        running: root.is_running;
        interval: 80ms;
        triggered => {
            root.spin-frame = root.spin-frame < 39.0 ? root.spin-frame + 1.0 : 0.0;
        }
    }
    property <float> drag-start-pointer-x: 0;
    property <float> drag-start-pointer-y: 0;
    property <float> drag-start-node-x: 0;
    property <float> drag-start-node-y: 0;
    property <bool> did-drag: false;
    property <bool> is-dragging: false;
    property <bool> is-resizing: false;
    property <float> resize-start-pointer-x: 0;
    property <float> resize-start-pointer-y: 0;
    property <float> resize-start-width: 0;
    property <float> resize-start-height: 0;
    property <float> inner-padding-bottom: grid_size * 0.8;
    property <bool> is-list-data-node: root.node_type == "message_list_data" || root.node_type == "qq_message_list_data";
    property <bool> is-function-boundary-node: root.node_type == "function_inputs" || root.node_type == "function_outputs";
    property <bool> shows-preview-row: root.preview_text != "" && !root.is-list-data-node;
    property <float> list-node-inset: grid_size * 0.5;
    property <float> list-node-top: grid_size * 1.1;
    property <float> list-node-width: root.width / 1px - grid_size * 1.0;
    property <float> list-node-height: min(grid_size * 7.0, root.height / 1px - grid_size * 2.0);
    property <float> list-node-column-width: grid_size * 2.2;
    property <float> list-node-row-height: grid_size * 1.5;
    property <float> list-node-button-size: grid_size * 0.7;
    property <float> list-node-list-padding: 4;
    property <float> list-node-row-padding: 3;
    property <float> list-node-row-spacing: 5;
    property <float> list-node-action-spacing: 2;
    property <float> list-node-port-row-y: grid_size * 1.1;
    property <bool> has-tools-editor: root.node_type == "brain";
    property <bool> has-function-editor: root.node_type == "function";
    property <bool> has-format-string-editor: root.node_type == "format_string";
    property <bool> has-json-extract-editor: root.node_type == "json_extract";
    property <bool> suppress-click: false;
    property <bool> shift-click-active: false;
    property <brush> boundary-card-bg: root.node_type == "function_inputs"
        ? AppTheme.function-input-node-bg
        : AppTheme.function-output-node-bg;
    property <brush> boundary-card-bg-pressed: root.node_type == "function_inputs"
        ? AppTheme.function-input-node-bg-pressed
        : AppTheme.function-output-node-bg-pressed;
    property <brush> boundary-card-border: root.node_type == "function_inputs"
        ? AppTheme.function-input-node-border
        : AppTheme.function-output-node-border;

    x: x_pos * 1px;
    y: y_pos * 1px;
    width: max(node_width, grid_size * node_width_cells) * 1px;
    height: max(
        node_height,
        grid_size * max(min_rows, header_rows + max(input_ports.length, output_ports.length)) + inner-padding-bottom
    ) * 1px;
    background: root.is-function-boundary-node
        ? (touch.pressed ? root.boundary-card-bg-pressed : root.boundary-card-bg)
        : (touch.pressed ? AppTheme.node-bg-pressed : AppTheme.node-bg);
    border-radius: 8px;
    border-width: (has_error || has_cycle) ? 2px : (is_selected ? 2px : 1px);
    border-color: has_error
        ? AppTheme.danger
        : (has_cycle
            ? AppTheme.warning
            : (is_selected
                ? AppTheme.selection
                : (root.is-function-boundary-node ? root.boundary-card-border : AppTheme.border)));

    touch := TouchArea {
        clicked => {
            if !root.suppress-click {
                root.node_clicked(root.node_id, root.shift-click-active);
            }
            root.suppress-click = false;
        }

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                if (event.button == PointerEventButton.right) {
                    root.suppress-click = true;
                    root.node_right_clicked(
                        root.node_id,
                        (self.mouse-x / 1px) + root.x / 1px,
                        (self.mouse-y / 1px) + root.y / 1px
                    );
                } else if (event.button == PointerEventButton.left) {
                    root.shift-click-active = event.modifiers.shift;
                    root.node_pointer_down(root.node_id, event.modifiers.shift);
                    root.suppress-click = false;
                    did-drag = false;
                    is-dragging = true;
                    drag-start-pointer-x = (self.mouse-x / 1px) + root.x / 1px;
                    drag-start-pointer-y = (self.mouse-y / 1px) + root.y / 1px;
                    drag-start-node-x = root.x / 1px;
                    drag-start-node-y = root.y / 1px;
                }
            } else if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                is-dragging = false;
                if did-drag {
                    let pointer-x = (self.mouse-x / 1px) + root.x / 1px;
                    let pointer-y = (self.mouse-y / 1px) + root.y / 1px;
                    let new-x = drag-start-node-x + (pointer-x - drag-start-pointer-x);
                    let new-y = drag-start-node-y + (pointer-y - drag-start-pointer-y);
                    root.suppress-click = true;
                    root.node_moved(new-x, new-y);
                    root.node_move_finished(new-x, new-y);
                }
                did-drag = false;
            }
        }

        moved => {
            if (self.pressed && is-dragging) {
                let pointer-x = (self.mouse-x / 1px) + root.x / 1px;
                let pointer-y = (self.mouse-y / 1px) + root.y / 1px;
                let delta-x = pointer-x - drag-start-pointer-x;
                let delta-y = pointer-y - drag-start-pointer-y;
                if !did-drag && delta-x * delta-x + delta-y * delta-y > 16 {
                    did-drag = true;
                }
                if !did-drag {
                    return;
                }
                let new-x = drag-start-node-x + (pointer-x - drag-start-pointer-x);
                let new-y = drag-start-node-y + (pointer-y - drag-start-pointer-y);
                root.node_moved(new-x, new-y);
            }
        }
    }

    CjkText {
        text: root.label;
        color: AppTheme.text-primary;
        horizontal-alignment: center;
        font-size: grid_size * 0.7 * 1px;
        font-weight: 700;
        height: (grid_size * (root.shows-preview-row ? 1 : (root.is-list-data-node ? 1 : header_rows))) * 1px;
        width: parent.width;
        x: 0px;
        y: 0px;
    }

    // Perimeter comet tail (continuous polyline) for EventProducer nodes while running.
    // 10 perimeter positions → 4 chained Path segments with tapering width/opacity.
    // Adjacent perimeter points are always on the same edge or at a corner,
    // so no segment ever crosses the node interior.
    // 40 frames × 80ms ≈ 3.2s/rev
    if root.is_running: Rectangle {
        x: 0px; y: 0px;
        width: root.width; height: root.height;
        background: transparent; clip: false;

        // 10 perimeter positions: p0 = lead, p9 = tail
        property <float> p0x: root.perim-cx(Math.mod(root.spin-frame,        40.0), root.width / 1px);
        property <float> p0y: root.perim-cy(Math.mod(root.spin-frame,        40.0), root.height / 1px);
        property <float> p1x: root.perim-cx(Math.mod(root.spin-frame + 39.0, 40.0), root.width / 1px);
        property <float> p1y: root.perim-cy(Math.mod(root.spin-frame + 39.0, 40.0), root.height / 1px);
        property <float> p2x: root.perim-cx(Math.mod(root.spin-frame + 38.0, 40.0), root.width / 1px);
        property <float> p2y: root.perim-cy(Math.mod(root.spin-frame + 38.0, 40.0), root.height / 1px);
        property <float> p3x: root.perim-cx(Math.mod(root.spin-frame + 37.0, 40.0), root.width / 1px);
        property <float> p3y: root.perim-cy(Math.mod(root.spin-frame + 37.0, 40.0), root.height / 1px);
        property <float> p4x: root.perim-cx(Math.mod(root.spin-frame + 36.0, 40.0), root.width / 1px);
        property <float> p4y: root.perim-cy(Math.mod(root.spin-frame + 36.0, 40.0), root.height / 1px);
        property <float> p5x: root.perim-cx(Math.mod(root.spin-frame + 35.0, 40.0), root.width / 1px);
        property <float> p5y: root.perim-cy(Math.mod(root.spin-frame + 35.0, 40.0), root.height / 1px);
        property <float> p6x: root.perim-cx(Math.mod(root.spin-frame + 34.0, 40.0), root.width / 1px);
        property <float> p6y: root.perim-cy(Math.mod(root.spin-frame + 34.0, 40.0), root.height / 1px);
        property <float> p7x: root.perim-cx(Math.mod(root.spin-frame + 33.0, 40.0), root.width / 1px);
        property <float> p7y: root.perim-cy(Math.mod(root.spin-frame + 33.0, 40.0), root.height / 1px);
        property <float> p8x: root.perim-cx(Math.mod(root.spin-frame + 32.0, 40.0), root.width / 1px);
        property <float> p8y: root.perim-cy(Math.mod(root.spin-frame + 32.0, 40.0), root.height / 1px);
        property <float> p9x: root.perim-cx(Math.mod(root.spin-frame + 31.0, 40.0), root.width / 1px);
        property <float> p9y: root.perim-cy(Math.mod(root.spin-frame + 31.0, 40.0), root.height / 1px);

        // Segment tail (p9→p8→p7) — thinnest, faintest
        Path {
            x: 0px; y: 0px; width: 100%; height: 100%;
            viewbox-x: 0; viewbox-y: 0;
            viewbox-width: parent.width / 1px; viewbox-height: parent.height / 1px;
            commands: "M \{parent.p9x} \{parent.p9y} L \{parent.p8x} \{parent.p8y} L \{parent.p7x} \{parent.p7y}";
            stroke: #4caf5030;
            stroke-width: grid_size * 0.12 * 1px;
            fill: transparent;
        }
        // Segment (p7→p6→p5)
        Path {
            x: 0px; y: 0px; width: 100%; height: 100%;
            viewbox-x: 0; viewbox-y: 0;
            viewbox-width: parent.width / 1px; viewbox-height: parent.height / 1px;
            commands: "M \{parent.p7x} \{parent.p7y} L \{parent.p6x} \{parent.p6y} L \{parent.p5x} \{parent.p5y}";
            stroke: #4caf5065;
            stroke-width: grid_size * 0.18 * 1px;
            fill: transparent;
        }
        // Segment (p5→p4→p3)
        Path {
            x: 0px; y: 0px; width: 100%; height: 100%;
            viewbox-x: 0; viewbox-y: 0;
            viewbox-width: parent.width / 1px; viewbox-height: parent.height / 1px;
            commands: "M \{parent.p5x} \{parent.p5y} L \{parent.p4x} \{parent.p4y} L \{parent.p3x} \{parent.p3y}";
            stroke: #4caf50a0;
            stroke-width: grid_size * 0.24 * 1px;
            fill: transparent;
        }
        // Segment lead (p3→p2→p1→p0) — thickest, brightest
        Path {
            x: 0px; y: 0px; width: 100%; height: 100%;
            viewbox-x: 0; viewbox-y: 0;
            viewbox-width: parent.width / 1px; viewbox-height: parent.height / 1px;
            commands: "M \{parent.p3x} \{parent.p3y} L \{parent.p2x} \{parent.p2y} L \{parent.p1x} \{parent.p1y} L \{parent.p0x} \{parent.p0y}";
            stroke: #4caf50ff;
            stroke-width: grid_size * 0.30 * 1px;
            fill: transparent;
        }
    }

    if root.shows-preview-row: CjkText {
        text: root.preview_text;
        color: AppTheme.text-muted;
        horizontal-alignment: left;
        font-size: grid_size * 0.55 * 1px;
        height: (grid_size) * 1px;
        width: parent.width - (grid_size) * 1px;
        x: (grid_size * 0.5) * 1px;
        y: (grid_size * 1.0) * 1px;
        wrap: word-wrap;
        overflow: elide;
    }

    if root.node_type == "preview_message_list" && root.message_list.length > 0: ScrollView {
        x: (grid_size * 0.5) * 1px;
        y: (grid_size * 1.2) * 1px;
        width: root.width - (grid_size * 1.0) * 1px;
        height: min((grid_size * 6.0) * 1px, root.height - (grid_size * 2.0) * 1px);

        VerticalBox {
            spacing: 4px;
            padding: 4px;

            for msg[idx] in root.message_list: Rectangle {
                height: (grid_size * 2.0) * 1px;
                border-radius: 6px;
                background: msg.role == "system" ? #2C3E50 :
                           msg.role == "user" ? #3498DB :
                           msg.role == "assistant" ? #27AE60 :
                           #E67E22;
                border-width: 1px;
                border-color: msg.role == "system" ? #34495E :
                             msg.role == "user" ? #2980B9 :
                             msg.role == "assistant" ? #229954 :
                             #D35400;

                VerticalLayout {
                    padding: 6px;
                    spacing: 2px;

                    CjkText {
                        text: msg.role == "system" ? "系统" :
                              msg.role == "user" ? "用户" :
                              msg.role == "assistant" ? "助手" :
                              "工具";
                        color: #FFFFFF;
                        font-size: grid_size * 0.45 * 1px;
                        font-weight: 700;
                        horizontal-alignment: left;
                    }

                    CjkText {
                        text: msg.content;
                        color: #FFFFFF;
                        font-size: grid_size * 0.5 * 1px;
                        horizontal-alignment: left;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }
        }
    }

    if root.node_type == "message_list_data": Rectangle {
        x: root.list-node-inset * 1px;
        y: root.list-node-top * 1px;
        width: root.list-node-width * 1px;
        height: root.list-node-height * 1px;
        background: transparent;

        VerticalLayout {
            padding: 4px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 6px;
                alignment: start;

                CjkText {
                    text: "messages";
                    color: AppTheme.text-secondary;
                    font-size: grid_size * 0.5 * 1px;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: grid_size * 0.9 * 1px;
                    height: grid_size * 0.9 * 1px;
                    background: AppTheme.primary;
                    border-radius: 4px;

                    CjkText {
                        text: "+";
                        color: AppTheme.text-on-primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: grid_size * 0.6 * 1px;
                        font-weight: 700;
                    }

                    TouchArea {
                        clicked => {
                            root.message_list_add(root.node_id);
                        }
                    }
                }
            }

            Rectangle {
                height: grid_size * 0.9 * 1px;
                background: AppTheme.node-bg-pressed;
                border-radius: 4px;

                HorizontalLayout {
                    padding: 4px;
                    spacing: 6px;

                    CjkText {
                        text: "role";
                        color: AppTheme.text-muted;
                        font-size: grid_size * 0.45 * 1px;
                        width: root.list-node-column-width * 1px;
                    }

                    CjkText {
                        text: "content";
                        color: AppTheme.text-muted;
                        font-size: grid_size * 0.45 * 1px;
                        horizontal-stretch: 1;
                    }
                }
            }

            ScrollView {
                height: min((grid_size * 5.0) * 1px, root.height - (grid_size * 3.0) * 1px);

                VerticalBox {
                    spacing: 4px;
                    padding: root.list-node-list-padding * 1px;

                    for msg[idx] in root.message_list: Rectangle {
                        height: root.list-node-row-height * 1px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        background: AppTheme.node-bg;

                        HorizontalLayout {
                            padding: root.list-node-row-padding * 1px;
                            spacing: root.list-node-row-spacing * 1px;

                            Rectangle {
                                width: root.list-node-column-width * 1px;
                                height: parent.height - 8px;
                                border-radius: 4px;
                                background: msg.role == "system" ? #2C3E50 :
                                           msg.role == "user" ? #3498DB :
                                           msg.role == "assistant" ? #27AE60 :
                                           #E67E22;
                                border-width: 1px;
                                border-color: msg.role == "system" ? #34495E :
                                             msg.role == "user" ? #2980B9 :
                                             msg.role == "assistant" ? #229954 :
                                             #D35400;

                                CjkText {
                                    text: msg.role == "system" ? "系统" :
                                          msg.role == "user" ? "用户" :
                                          msg.role == "assistant" ? "助手" :
                                          "工具";
                                    color: #FFFFFF;
                                    font-size: grid_size * 0.45 * 1px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    clicked => {
                                        root.message_list_cycle_role(root.node_id, idx);
                                    }
                                }
                            }

                            Rectangle {
                                height: parent.height - 8px;
                                border-radius: 4px;
                                background: AppTheme.node-bg-pressed;
                                border-width: 1px;
                                border-color: AppTheme.border;
                                horizontal-stretch: 1;

                                HorizontalLayout {
                                    width: 100%;
                                    height: 100%;
                                    padding: 2px;
                                    spacing: 4px;

                                    LineEdit {
                                        text: msg.content;
                                        placeholder-text: "输入内容";
                                        height: parent.height - 4px;
                                        horizontal-stretch: 1;
                                        edited(text) => {
                                            root.message_list_set_content(root.node_id, idx, text);
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: root.list-node-action-spacing * 1px;

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "↑";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_move_up(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "↓";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_move_down(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "+";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_insert(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.danger-bg;

                                            CjkText {
                                                text: "×";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.5 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_delete(root.node_id, idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.node_type == "qq_message_list_data": Rectangle {
        x: root.list-node-inset * 1px;
        y: root.list-node-top * 1px;
        width: root.list-node-width * 1px;
        height: root.list-node-height * 1px;
        background: transparent;

        VerticalLayout {
            padding: 4px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 6px;
                alignment: start;

                CjkText {
                    text: "messages";
                    color: AppTheme.text-secondary;
                    font-size: grid_size * 0.5 * 1px;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: grid_size * 0.9 * 1px;
                    height: grid_size * 0.9 * 1px;
                    background: AppTheme.primary;
                    border-radius: 4px;

                    CjkText {
                        text: "+";
                        color: AppTheme.text-on-primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: grid_size * 0.6 * 1px;
                        font-weight: 700;
                    }

                    TouchArea {
                        clicked => {
                            root.qq_message_list_add(root.node_id);
                        }
                    }
                }
            }

            Rectangle {
                height: grid_size * 0.9 * 1px;
                background: AppTheme.node-bg-pressed;
                border-radius: 4px;

                HorizontalLayout {
                    padding: 4px;
                    spacing: 6px;

                    CjkText {
                        text: "type";
                        color: AppTheme.text-muted;
                        font-size: grid_size * 0.45 * 1px;
                        width: root.list-node-column-width * 1px;
                    }

                    CjkText {
                        text: "value";
                        color: AppTheme.text-muted;
                        font-size: grid_size * 0.45 * 1px;
                        horizontal-stretch: 1;
                    }
                }
            }

            ScrollView {
                height: min((grid_size * 5.0) * 1px, root.height - (grid_size * 3.0) * 1px);

                VerticalBox {
                    spacing: 4px;
                    padding: root.list-node-list-padding * 1px;

                    for msg[idx] in root.message_list: Rectangle {
                        height: root.list-node-row-height * 1px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        background: AppTheme.node-bg;

                        HorizontalLayout {
                            padding: root.list-node-row-padding * 1px;
                            spacing: root.list-node-row-spacing * 1px;

                            Rectangle {
                                width: root.list-node-column-width * 1px;
                                height: parent.height - 8px;
                                border-radius: 4px;
                                background: msg.role == "text" ? #3498DB :
                                           msg.role == "at" ? #27AE60 :
                                           #9B59B6;
                                border-width: 1px;
                                border-color: msg.role == "text" ? #2980B9 :
                                             msg.role == "at" ? #229954 :
                                             #8E44AD;

                                CjkText {
                                    text: msg.role == "text" ? "文本" :
                                          msg.role == "at" ? "@目标" :
                                          "引用";
                                    color: #FFFFFF;
                                    font-size: grid_size * 0.45 * 1px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    clicked => {
                                        root.qq_message_list_cycle_type(root.node_id, idx);
                                    }
                                }
                            }

                            Rectangle {
                                height: parent.height - 8px;
                                border-radius: 4px;
                                background: AppTheme.node-bg-pressed;
                                border-width: 1px;
                                border-color: AppTheme.border;
                                horizontal-stretch: 1;

                                HorizontalLayout {
                                    width: 100%;
                                    height: 100%;
                                    padding: 2px;
                                    spacing: 4px;

                                    LineEdit {
                                        text: msg.content;
                                        placeholder-text: msg.role == "text" ? "输入文本" :
                                                          msg.role == "at" ? "目标QQ号" : "消息ID";
                                        height: parent.height - 4px;
                                        horizontal-stretch: 1;
                                        edited(text) => {
                                            root.qq_message_list_set_content(root.node_id, idx, text);
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: root.list-node-action-spacing * 1px;

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "↑";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_move_up(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "↓";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_move_down(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.primary-muted;

                                            CjkText {
                                                text: "+";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.45 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.qq_message_list_insert(root.node_id, idx);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: root.list-node-button-size * 1px;
                                            height: root.list-node-button-size * 1px;
                                            border-radius: 3px;
                                            background: AppTheme.danger-bg;

                                            CjkText {
                                                text: "×";
                                                color: AppTheme.text-primary;
                                                font-size: grid_size * 0.5 * 1px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.message_list_delete(root.node_id, idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    for port[i] in input_ports: Rectangle {
        x: (grid_size * 0.2) * 1px;
        y: (grid_size * header_rows + i * grid_size + grid_size * 0.2) * 1px;
        width: (grid_size * 0.6) * 1px;
        height: (grid_size * 0.6) * 1px;
        border-radius: (grid_size * 0.3) * 1px;
        visible: !root.is-list-data-node &&
                 !(root.node_type == "message_event_type_filter" && port.name == "filter_type") &&
                 !((root.node_type == "qq_natural_language_reply" || root.node_type == "llm_qq_natural_language_reply" || root.node_type == "send_qq_message_batches") && port.name == "target_type") &&
                 !((root.node_type == "string_to_openai_message" || root.node_type == "as_system_openai_message") && port.name == "role") &&
                 !(root.node_type == "format_string" && port.name == "template") &&
                 !(root.node_type == "json_extract" && port.name == "fields_config");
        background: (port.is_connected || port.has_value) ? AppTheme.primary-muted : (port.is_required ? AppTheme.danger-bg : AppTheme.node-port-bg);
        border-width: 1px;
        border-color: (port.is_connected || port.has_value) ? AppTheme.primary : (port.is_required ? AppTheme.danger : AppTheme.node-port-border);

        TouchArea {
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                    root.port_right_clicked(
                        root.node_id,
                        port.name,
                        (self.mouse-x / 1px) + root.x / 1px,
                        (self.mouse-y / 1px) + root.y / 1px
                    );
                } else if (event.kind == PointerEventKind.down) {
                    root.port_clicked(root.node_id, port.name, true);
                }
            }
        }
    }

    for port[i] in input_ports: Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * header_rows + i * grid_size) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;
        visible: !root.is-list-data-node &&
                 !(root.node_type == "message_event_type_filter" && port.name == "filter_type") &&
                 !((root.node_type == "qq_natural_language_reply" || root.node_type == "llm_qq_natural_language_reply" || root.node_type == "send_qq_message_batches") && port.name == "target_type") &&
                 !((root.node_type == "string_to_openai_message" || root.node_type == "as_system_openai_message") && port.name == "role") &&
                 !(root.node_type == "format_string" && port.name == "template") &&
                 !(root.node_type == "json_extract" && port.name == "fields_config");

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: port.name;
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }

            if (port.bound_name != ""): Rectangle {
                background: port.bound_kind == "variable" ? #0f766e20 : #5b21b620;
                border-radius: 4px;
                border-width: 1px;
                border-color: port.bound_kind == "variable" ? #14b8a640 : #7c3aed40;
                width: min(parent.width * 0.5, 120px);
                HorizontalLayout {
                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                    CjkText {
                        text: (port.bound_kind == "variable" ? "V " : "§ ") + port.bound_name;
                        font-size: grid_size * 0.45 * 1px;
                        color: port.bound_kind == "variable" ? #5eead4 : #a78bfa;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }

            if (!port.is_connected && port.bound_name == "" && (port.data_type == "String" || port.data_type == "Integer" || port.data_type == "Float" || port.data_type == "Password")): LineEdit {
                width: min(parent.width * 0.5, 120px);
                height: (grid_size * 0.8) * 1px;
                text: port.inline_text;
                placeholder-text: port.data_type;
                input-type: port.data_type == "Password" ? password : text;
                edited(text) => {
                    root.inline_port_text_changed(root.node_id, port.name, text);
                }
            }

            if (!port.is_connected && port.bound_name == "" && (port.data_type == "Boolean")): CheckBox {
                height: (grid_size * 0.7) * 1px;
                text: "";
                checked: port.inline_bool;
                toggled => {
                    root.inline_port_bool_changed(root.node_id, port.name, self.checked);
                }
            }
        }
    }

    if root.node_type == "string_data": Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * header_rows) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: "text";
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }

            LineEdit {
                width: min(parent.width * 0.6, 150px);
                height: (grid_size * 0.8) * 1px;
                text: root.string_data_text;
                placeholder-text: "输入字符串";
                edited(text) => {
                    root.inline_port_text_changed(root.node_id, "text", text);
                }
            }
        }
    }

    if root.node_type == "set_variable": Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * (header_rows + 1)) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: "变量";
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
            }

            ComboBox {
                width: min(parent.width * 0.6, 130px);
                height: (grid_size * 0.8) * 1px;
                model: root.set_variable_options;
                current-value: root.set_variable_name;
                selected(value) => {
                    root.set_variable_node_selected(root.node_id, value);
                }
            }
        }
    }

    if root.node_type == "message_event_type_filter": Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * (header_rows + 1)) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: "消息类型";
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }

            ComboBox {
                width: min(parent.width * 0.65, 120px);
                height: (grid_size * 0.85) * 1px;
                model: ["好友消息", "群组消息"];
                current-index: root.message_event_filter_type == "group" ? 1 : 0;
                selected(value) => {
                    root.inline_port_text_changed(
                        root.node_id,
                        "filter_type",
                        value == "群组消息" ? "group" : "private"
                    );
                }
            }
        }
    }

    if root.node_type == "string_to_openai_message" || root.node_type == "as_system_openai_message": Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * (header_rows + 1)) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: "role";
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }

            ComboBox {
                width: min(parent.width * 0.65, 140px);
                height: (grid_size * 0.85) * 1px;
                model: ["system", "user", "assistant", "tool"];
                current-index: root.message_event_filter_type == "user" ? 1 :
                               root.message_event_filter_type == "assistant" ? 2 :
                               root.message_event_filter_type == "tool" ? 3 : 0;
                selected(value) => {
                    root.inline_port_text_changed(root.node_id, "role", value);
                }
            }
        }
    }

    if root.node_type == "qq_natural_language_reply" || root.node_type == "llm_qq_natural_language_reply" || root.node_type == "send_qq_message_batches": Rectangle {
        x: (grid_size) * 1px;
        y: (grid_size * (header_rows + 3)) * 1px;
        width: root.width - (grid_size * 2.5) * 1px;
        height: (grid_size) * 1px;

        HorizontalLayout {
            alignment: start;
            spacing: 5px;

            CjkText {
                text: "target_type";
                color: AppTheme.text-secondary;
                font-size: grid_size * 0.5 * 1px;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }

            ComboBox {
                width: min(parent.width * 0.65, 120px);
                height: (grid_size * 0.85) * 1px;
                model: ["好友", "群组"];
                current-index: root.message_event_filter_type == "group" ? 1 : 0;
                selected(value) => {
                    root.inline_port_text_changed(
                        root.node_id,
                        "target_type",
                        value == "群组" ? "group" : "friend"
                    );
                }
            }
        }
    }

    for port[i] in output_ports: Rectangle {
        x: root.width - (grid_size * 0.8) * 1px;
        y: ((root.is-list-data-node ? (root.list-node-port-row-y + i * grid_size) : (grid_size * header_rows + i * grid_size)) + grid_size * 0.2) * 1px;
        width: (grid_size * 0.6) * 1px;
        height: (grid_size * 0.6) * 1px;
        border-radius: (grid_size * 0.3) * 1px;
        background: port.is_connected ? AppTheme.primary-muted : (port.is_required ? AppTheme.danger-bg : AppTheme.node-port-bg);
        border-width: 1px;
        border-color: port.is_connected ? AppTheme.primary : (port.is_required ? AppTheme.danger : AppTheme.node-port-border);

        TouchArea {
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    root.port_clicked(root.node_id, port.name, false);
                }
            }
        }
    }

    for port[i] in output_ports: CjkText {
        text: port.name;
        color: AppTheme.text-secondary;
        font-size: grid_size * 0.5 * 1px;
        vertical-alignment: center;
        horizontal-alignment: right;
        x: (grid_size) * 1px;
        y: (root.is-list-data-node ? (root.list-node-port-row-y + i * grid_size) : (grid_size * header_rows + i * grid_size)) * 1px;
        width: root.width - (grid_size * 2) * 1px;
        height: (grid_size) * 1px;
    }

    if root.has-tools-editor: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - self.height - (grid_size * 0.45) * 1px;
        width: max((grid_size * 4.4) * 1px, root.width * 0.52);
        height: (grid_size * 0.9) * 1px;
        background: AppTheme.primary-muted;
        border-radius: 5px;
        border-width: 1px;
        border-color: AppTheme.primary;

        TouchArea {
            clicked => { root.edit_tools_clicked(root.node_id); }
        }

        CjkText {
            text: "编辑 Tools";
            color: AppTheme.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: (grid_size * 0.48) * 1px;
            font-weight: 700;
        }
    }

    if root.has-format-string-editor: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - self.height - (grid_size * 0.45) * 1px;
        width: max((grid_size * 5.0) * 1px, root.width * 0.55);
        height: (grid_size * 0.9) * 1px;
        background: AppTheme.primary-muted;
        border-radius: 5px;
        border-width: 1px;
        border-color: AppTheme.primary;

        TouchArea {
            clicked => { root.edit_format_string_clicked(root.node_id); }
        }

        CjkText {
            text: "编辑格式化文本";
            color: AppTheme.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: (grid_size * 0.48) * 1px;
            font-weight: 700;
        }
    }

    if root.has-function-editor: Rectangle {
        x: (grid_size * 0.5) * 1px;
        y: root.height - (grid_size * 2.3) * 1px;
        width: root.width - (grid_size * 1.0) * 1px;
        height: (grid_size * 1.8) * 1px;
        background: transparent;

        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                background: AppTheme.primary-muted;
                border-radius: 5px;
                border-width: 1px;
                border-color: AppTheme.primary;

                TouchArea {
                    clicked => { root.edit_function_clicked(root.node_id); }
                }

                CjkText {
                    text: "编辑函数";
                    color: AppTheme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: (grid_size * 0.48) * 1px;
                    font-weight: 700;
                    width: 100%;
                    height: 100%;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: AppTheme.surface-overlay;
                border-radius: 5px;
                border-width: 1px;
                border-color: AppTheme.border;

                TouchArea {
                    clicked => { root.enter_function_subgraph_clicked(root.node_id); }
                }

                CjkText {
                    text: "进入子图";
                    color: AppTheme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: (grid_size * 0.48) * 1px;
                    font-weight: 700;
                    width: 100%;
                    height: 100%;
                }
            }
        }
    }

    if root.has-json-extract-editor: Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - self.height - (grid_size * 0.45) * 1px;
        width: max((grid_size * 5.0) * 1px, root.width * 0.55);
        height: (grid_size * 0.9) * 1px;
        background: AppTheme.primary-muted;
        border-radius: 5px;
        border-width: 1px;
        border-color: AppTheme.primary;

        TouchArea {
            clicked => { root.edit_json_extract_clicked(root.node_id); }
        }

        CjkText {
            text: "编辑提取字段";
            color: AppTheme.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: (grid_size * 0.48) * 1px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: root.width - (grid_size * 0.6) * 1px;
        y: root.height - (grid_size * 0.5) * 1px - (grid_size * 0.1) * 1px;
        width: (grid_size * 0.5) * 1px;
        height: (grid_size * 0.5) * 1px;
        background: AppTheme.border;
        border-radius: 3px;

        TouchArea {
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    root.is-resizing = true;
                    root.resize-start-pointer-x = (self.mouse-x / 1px) + root.x / 1px;
                    root.resize-start-pointer-y = (self.mouse-y / 1px) + root.y / 1px;
                    root.resize-start-width = root.width / 1px;
                    root.resize-start-height = root.height / 1px;
                } else if (event.kind == PointerEventKind.up) {
                    root.is-resizing = false;
                    root.node_resize_finished(root.width / 1px, root.height / 1px);
                }
            }

            moved => {
                if (self.pressed && root.is-resizing) {
                    let pointer-x = (self.mouse-x / 1px) + root.x / 1px;
                    let pointer-y = (self.mouse-y / 1px) + root.y / 1px;
                    let new-width = root.resize-start-width + (pointer-x - root.resize-start-pointer-x);
                    let new-height = root.resize-start-height + (pointer-y - root.resize-start-pointer-y);
                    root.node_width = new-width;
                    root.node_height = new-height;
                    root.node_resized(root.node_width, root.node_height);
                }
            }
        }
    }

    Rectangle {
        x: parent.width - self.width - (grid_size * 0.3) * 1px;
        y: (grid_size * 0.2) * 1px;
        width: (grid_size * 0.9) * 1px;
        height: (grid_size * 0.9) * 1px;
        background: AppTheme.category-bg;
        border-radius: (grid_size * 0.45) * 1px;
        border-width: 1px;
        border-color: AppTheme.border-light;
        opacity: 0.75;

        TouchArea {
            clicked => { root.show_help(root.node_id, root.node_type); }
        }

        CjkText {
            text: "?";
            color: AppTheme.text-secondary;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: (grid_size * 0.5) * 1px;
            font-weight: 700;
        }
    }
}
