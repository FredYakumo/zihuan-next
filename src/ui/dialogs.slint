import { HorizontalBox, VerticalBox, ScrollView, LineEdit, CheckBox, ComboBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { NodeTypeVm, PortHelpVm, HyperParameterVm } from "types.slint";
import { CjkButton, CjkDeleteButton, CjkText } from "components/buttons.slint";

export component ErrorDialog inherits Rectangle {
    in property <string> error_message;
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 800px;
        height: 200px;
        background: AppTheme.error-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.error-border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 16px;

                Rectangle {
                    width: 48px;

                    VerticalLayout {
                        alignment: start;

                        Rectangle {
                            width: 36px;
                            height: 36px;
                            border-radius: 18px;
                            background: AppTheme.error-icon-bg;

                            CjkText {
                                text: "!";
                                font-size: 24px;
                                color: AppTheme.text-on-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-weight: 700;
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 8px;

                    CjkText {
                        text: "节点图执行失败";
                        font-size: 16px;
                        color: AppTheme.error-title;
                        font-weight: 700;
                        horizontal-alignment: left;
                    }

                    Rectangle {
                        background: AppTheme.error-message-bg;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: AppTheme.error-message-border;

                        ScrollView {
                            VerticalLayout {
                                padding: 10px;

                                CjkText {
                                    text: root.error_message;
                                    font-size: 12px;
                                    color: AppTheme.error-message-text;
                                    wrap: word-wrap;
                                    horizontal-alignment: left;
                                }
                            }
                        }
                    }
                }
            }

            HorizontalBox {
                alignment: center;

                CjkButton {
                    text: "确定";
                    clicked => { root.close(); }
                }
            }
        }
    }
}

export component SaveConfirmDialog inherits Rectangle {
    in property <string> message;
    callback save();
    callback discard();
    callback cancel();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 800px;
        height: 200px;
        background: AppTheme.node-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            CjkText {
                text: root.message;
                font-size: 16px;
                color: AppTheme.text-primary;
                font-weight: 700;
                horizontal-alignment: left;
            }

            HorizontalBox {
                alignment: center;
                spacing: 12px;

                CjkButton {
                    text: "保存";
                    clicked => { root.save(); }
                }

                CjkDeleteButton {
                    text: "不保存";
                    clicked => { root.discard(); }
                }

                CjkButton {
                    text: "取消";
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}

export component RunningConfirmDialog inherits Rectangle {
    in property <string> message;
    callback confirm_close();
    callback cancel();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 800px;
        height: 200px;
        background: AppTheme.node-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            CjkText {
                text: root.message;
                font-size: 16px;
                color: AppTheme.text-primary;
                font-weight: 700;
                horizontal-alignment: left;
            }

            HorizontalBox {
                alignment: center;
                spacing: 12px;

                CjkDeleteButton {
                    text: "停止并关闭";
                    clicked => { root.confirm_close(); }
                }

                CjkButton {
                    text: "取消";
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}

export component NodeSelector inherits Rectangle {
    in property <[NodeTypeVm]> node_types;
    in property <[string]> categories;
    callback add_node(string);
    callback close();
    callback filter(string, string);

    property <string> current_search: "";
    property <string> current_category: "";
    property <bool> show_help_panel: false;
    property <string> help_type_id: "";
    property <string> help_display_name: "";
    property <string> help_category: "";
    property <string> help_description: "";
    property <[PortHelpVm]> help_input_ports;
    property <[PortHelpVm]> help_output_ports;

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.show_help_panel ? 1080px : 700px;
        height: 600px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        HorizontalLayout {
            padding: 0;
            spacing: 0;

            // ── LEFT: node list panel ──
            VerticalBox {
                width: 680px;
                padding: 16px;
                spacing: 12px;

                CjkText {
                    text: "选择节点类型";
                    font-size: 18px;
                    color: AppTheme.text-primary;
                    horizontal-alignment: center;
                    height: 30px;
                }

                VerticalBox {
                    spacing: 8px;

                    HorizontalBox {
                        height: 50px;
                        CjkText {
                            text: "搜索:";
                            vertical-alignment: center;
                            width: 50px;
                            color: AppTheme.text-secondary;
                        }
                        LineEdit {
                            height: 35px;
                            placeholder-text: "输入名称、类型、分类或描述...";
                            edited(text) => {
                                root.current_search = text;
                                root.filter(root.current_search, root.current_category);
                            }
                        }
                    }

                    HorizontalBox {
                        height: 50px;
                        CjkText {
                            text: "分类:";
                            vertical-alignment: center;
                            width: 50px;
                            color: AppTheme.text-secondary;
                        }
                        ScrollView {
                            viewport-height: 30px;
                            height: 40px;
                            HorizontalLayout {
                                spacing: 8px;
                                padding-right: 8px;
                                alignment: start;

                                Rectangle {
                                    width: 60px;
                                    height: 30px;
                                    border-radius: 4px;
                                    background: root.current_category == "" ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            root.current_category = "";
                                            root.filter(root.current_search, root.current_category);
                                        }
                                    }

                                    CjkText {
                                        text: "全部";
                                        color: root.current_category == "" ? AppTheme.category-text-selected : AppTheme.category-text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 12px;
                                    }
                                }

                                for category in root.categories : Rectangle {
                                    width: 80px;
                                    height: 30px;
                                    border-radius: 4px;
                                    background: root.current_category == category ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            root.current_category = category;
                                            root.filter(root.current_search, root.current_category);
                                        }
                                    }

                                    CjkText {
                                        text: category;
                                        color: root.current_category == category ? AppTheme.category-text-selected : AppTheme.category-text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 12px;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    background: AppTheme.background;
                    border-radius: 6px;
                    border-color: AppTheme.border-light;
                    border-width: 1px;

                    ScrollView {
                        viewport-width: parent.width - 20px;
                        viewport-height: root.node_types.length * 100px;

                        VerticalBox {
                            padding: 8px;
                            spacing: 8px;
                            alignment: start;

                            for node_type in root.node_types: Rectangle {
                                height: 80px;
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: root.show_help_panel && root.help_type_id == node_type.type_id ? 2px : 1px;
                                border-color: root.show_help_panel && root.help_type_id == node_type.type_id ? AppTheme.selection : AppTheme.border;

                                TouchArea {
                                    clicked => {
                                        root.add_node(node_type.type_id);
                                        root.close();
                                    }
                                }

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        CjkText {
                                            text: node_type.display_name;
                                            font-size: 16px;
                                            color: AppTheme.text-primary;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;

                                                HorizontalLayout {
                                                    padding-left: 6px;
                                                    padding-right: 6px;
                                                    padding-top: 2px;
                                                    padding-bottom: 2px;
                                                    CjkText {
                                                        text: node_type.category;
                                                        font-size: 11px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    CjkText {
                                        text: node_type.description;
                                        font-size: 13px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                        vertical-alignment: top;
                                        overflow: elide;
                                    }
                                }

                                // "?" help button — top-right corner, declared last so it's on top
                                Rectangle {
                                    x: parent.width - self.width - 6px;
                                    y: 6px;
                                    width: 22px;
                                    height: 22px;
                                    background: root.show_help_panel && root.help_type_id == node_type.type_id
                                        ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-radius: 11px;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            if root.show_help_panel && root.help_type_id == node_type.type_id {
                                                root.show_help_panel = false;
                                            } else {
                                                root.help_type_id = node_type.type_id;
                                                root.help_display_name = node_type.display_name;
                                                root.help_category = node_type.category;
                                                root.help_description = node_type.description;
                                                root.help_input_ports = node_type.input_ports;
                                                root.help_output_ports = node_type.output_ports;
                                                root.show_help_panel = true;
                                            }
                                        }
                                    }

                                    CjkText {
                                        text: "?";
                                        color: root.show_help_panel && root.help_type_id == node_type.type_id
                                            ? AppTheme.category-text-selected : AppTheme.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalBox {
                    alignment: center;
                    CjkButton {
                        text: "取消";
                        clicked => { root.close(); }
                    }
                }
            }            // ── RIGHT: help panel (only visible when show_help_panel) ──
            if root.show_help_panel: Rectangle {
                width: 380px;
                background: AppTheme.surface;

                // Left-edge separator
                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 1px;
                    height: parent.height;
                    background: AppTheme.border;
                }

                VerticalBox {
                    padding: 16px;
                    spacing: 10px;

                    // Title row
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            CjkText {
                                text: "节点帮助";
                                font-size: 14px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                background: AppTheme.category-bg;
                                border-radius: 11px;
                                border-width: 1px;
                                border-color: AppTheme.border-light;
                                TouchArea {
                                    clicked => { root.show_help_panel = false; }
                                }
                                CjkText {
                                    text: "×";
                                    color: AppTheme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 14px;
                                    font-weight: 700;
                                }
                            }
                        }
                    }

                    // Node name + category badge
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            CjkText {
                                text: root.help_display_name;
                                font-size: 18px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                background: AppTheme.category-bg;
                                border-radius: 4px;
                                HorizontalLayout {
                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                    CjkText {
                                        text: root.help_category;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                    }
                                }
                            }
                        }
                    }

                    // Description
                    CjkText {
                        text: root.help_description;
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                        wrap: word-wrap;
                    }

                    // Separator
                    Rectangle {
                        height: 1px;
                        background: AppTheme.border;
                    }

                    // Ports scroll area
                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 8px;
                            padding: 0;
                            alignment: start;

                            if root.help_input_ports.length > 0: CjkText {
                                text: "输入端口";
                                font-size: 12px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                                height: 20px;
                            }

                            for port in root.help_input_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 3px;

                                    HorizontalLayout {
                                        spacing: 5px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 11px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        if port.required: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: #b3440020;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: "必填";
                                                        font-size: 10px;
                                                        color: AppTheme.danger;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if root.help_output_ports.length > 0: Rectangle {
                                height: 10px;
                            }

                            if root.help_output_ports.length > 0: CjkText {
                                text: "输出端口";
                                font-size: 12px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                                height: 20px;
                            }

                            for port in root.help_output_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 3px;

                                    HorizontalLayout {
                                        spacing: 5px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 11px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
export component NodeHelpDialog inherits Rectangle {
    in property <NodeTypeVm> node_data;
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 680px;
        height: 560px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title row
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: root.node_data.display_name;
                        font-size: 20px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        background: AppTheme.category-bg;
                        border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px;
                            CjkText {
                                text: root.node_data.category;
                                font-size: 12px;
                                color: AppTheme.text-muted;
                            }
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: start;
                    Rectangle {
                        width: 26px;
                        height: 26px;
                        background: AppTheme.category-bg;
                        border-radius: 13px;
                        border-width: 1px;
                        border-color: AppTheme.border-light;
                        TouchArea {
                            clicked => { root.close(); }
                        }
                        CjkText {
                            text: "×";
                            color: AppTheme.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }
                }
            }

            // Description
            CjkText {
                text: root.node_data.description;
                font-size: 13px;
                color: AppTheme.text-secondary;
                wrap: word-wrap;
            }

            // Separator
            Rectangle {
                height: 1px;
                background: AppTheme.border;
            }

            // Ports area (Two columns)
            HorizontalLayout {
                vertical-stretch: 1;
                spacing: 20px;

                // Left column - Input ports
                VerticalLayout {
                    horizontal-stretch: 1;
                    if root.node_data.input_ports.length > 0: CjkText {
                        text: "输入端口";
                        font-size: 13px;
                        font-weight: 700;
                        color: AppTheme.text-secondary;
                        height: 28px;
                        vertical-alignment: center;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 8px;
                            padding: 0px;
                            padding-bottom: 12px;
                            alignment: start;

                            for port in root.node_data.input_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 12px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        if port.required: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: #b3440020;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: "必填";
                                                        font-size: 10px;
                                                        color: AppTheme.danger;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }

                // Right column - Output ports
                VerticalLayout {
                    horizontal-stretch: 1;
                    if root.node_data.output_ports.length > 0: CjkText {
                        text: "输出端口";
                        font-size: 13px;
                        font-weight: 700;
                        color: AppTheme.text-secondary;
                        height: 28px;
                        vertical-alignment: center;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 8px;
                            padding: 0px;
                            padding-bottom: 12px;
                            alignment: start;

                            for port in root.node_data.output_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 12px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}


export component HyperParameterManagerDialog inherits Rectangle {
    in property <[HyperParameterVm]> hyperparameters;
    callback add(string, string, bool, string);   // name, data_type, required, description
    callback delete(string);                       // name
    callback set_value(string, string);            // name, value
    callback toggle_required(string);              // name
    callback close();

    property <string> new_name: "";
    property <string> new_type: "String";
    property <bool> new_required: false;
    property <string> new_description: "";

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 680px;
        height: 560px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title row
            HorizontalLayout {
                spacing: 12px;
                CjkText {
                    text: "超参数管理";
                    font-size: 18px;
                    font-weight: 700;
                    color: AppTheme.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Rectangle {
                    width: 26px;
                    height: 26px;
                    background: AppTheme.category-bg;
                    border-radius: 13px;
                    border-width: 1px;
                    border-color: AppTheme.border-light;
                    TouchArea { clicked => { root.close(); } }
                    CjkText {
                        text: "×";
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }
            }

            // Existing hyperparameters list
            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.background;
                border-radius: 6px;
                border-color: AppTheme.border-light;
                border-width: 1px;

                ScrollView {
                    viewport-height: max(100px, root.hyperparameters.length * 64px);

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;

                        if root.hyperparameters.length == 0: CjkText {
                            text: "暂无超参数";
                            color: AppTheme.text-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }

                        for hp in root.hyperparameters: Rectangle {
                            height: 52px;
                            background: AppTheme.surface-overlay;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: AppTheme.border;

                            HorizontalLayout {
                                padding: 8px;
                                spacing: 8px;

                                // Name badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: #5b21b620;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: #7c3aed40;
                                        width: 100px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.name;
                                                font-size: 11px;
                                                font-weight: 700;
                                                color: #a78bfa;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }

                                // Type badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: AppTheme.category-bg;
                                        border-radius: 4px;
                                        width: 60px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.data_type;
                                                font-size: 10px;
                                                color: AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                // Value editor
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    if hp.data_type != "Boolean" && hp.data_type != "Password": LineEdit {
                                        height: 28px;
                                        text: hp.value;
                                        placeholder-text: "输入默认值";
                                        edited(text) => {
                                            root.set_value(hp.name, text);
                                        }
                                    }
                                    if hp.data_type == "Password": LineEdit {
                                        height: 28px;
                                        input-type: password;
                                        text: hp.value;
                                        placeholder-text: "输入密码";
                                        edited(text) => {
                                            root.set_value(hp.name, text);
                                        }
                                    }
                                    if hp.data_type == "Boolean": HorizontalLayout {
                                        alignment: start;
                                        spacing: 4px;
                                        CheckBox {
                                            checked: hp.value == "true";
                                            toggled => {
                                                root.set_value(hp.name, self.checked ? "true" : "false");
                                            }
                                        }
                                        CjkText {
                                            text: hp.value == "true" ? "true" : "false";
                                            color: AppTheme.text-secondary;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Required badge (clickable toggle)
                                VerticalLayout {
                                    alignment: center;
                                    width: 56px;
                                    Rectangle {
                                        background: hp.required ? #b3440020 : AppTheme.category-bg;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: hp.required ? #b3440040 : AppTheme.border-light;
                                        TouchArea {
                                            clicked => { root.toggle_required(hp.name); }
                                        }
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.required ? "必填" : "可选";
                                                font-size: 10px;
                                                color: hp.required ? AppTheme.danger : AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                // Delete button
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 24px;
                                        height: 24px;
                                        background: AppTheme.danger-bg;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: AppTheme.danger;
                                        TouchArea {
                                            clicked => { root.delete(hp.name); }
                                        }
                                        CjkText {
                                            text: "×";
                                            color: AppTheme.danger;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Separator
            Rectangle { height: 1px; background: AppTheme.border; }

            // Add new hyperparameter form
            VerticalLayout {
                spacing: 8px;

                CjkText {
                    text: "新增超参数";
                    font-size: 13px;
                    font-weight: 700;
                    color: AppTheme.text-secondary;
                }

                HorizontalLayout {
                    spacing: 8px;

                    LineEdit {
                        horizontal-stretch: 1;
                        height: 32px;
                        placeholder-text: "参数名称";
                        text: root.new_name;
                        edited(text) => { root.new_name = text; }
                    }

                    ComboBox {
                        width: 90px;
                        height: 32px;
                        model: ["String", "Integer", "Float", "Boolean", "Password"];
                        current-value: root.new_type;
                        selected(val) => { root.new_type = val; }
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        alignment: center;
                        width: 60px;
                        CheckBox {
                            checked: root.new_required;
                            toggled => { root.new_required = self.checked; }
                        }
                        CjkText {
                            text: "必填";
                            color: AppTheme.text-secondary;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }

                    CjkButton {
                        text: "添加";
                        clicked => {
                            if (root.new_name != "") {
                                root.add(root.new_name, root.new_type, root.new_required, root.new_description);
                                root.new_name = "";
                                root.new_required = false;
                                root.new_description = "";
                            }
                        }
                    }
                }
            }
        }
    }
}


export component PortBindHyperparamDialog inherits Rectangle {
    in property <[HyperParameterVm]> compatible_params;
    in property <string> current_binding;
    in property <string> port_name;
    callback bind(string);     // name
    callback clear_binding();
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 480px;
        height: 420px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: "绑定超参数";
                        font-size: 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }
                    CjkText {
                        text: "端口: " + root.port_name;
                        font-size: 12px;
                        color: AppTheme.text-muted;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 26px;
                    height: 26px;
                    background: AppTheme.category-bg;
                    border-radius: 13px;
                    border-width: 1px;
                    border-color: AppTheme.border-light;
                    TouchArea { clicked => { root.close(); } }
                    CjkText {
                        text: "×";
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }
            }

            // Current binding info
            if root.current_binding != "": HorizontalLayout {
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: "当前绑定: " + root.current_binding;
                        font-size: 12px;
                        color: #a78bfa;
                    }
                }
                CjkDeleteButton {
                    text: "清除绑定";
                    clicked => { root.clear_binding(); }
                }
            }

            // Compatible params list
            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.background;
                border-radius: 6px;
                border-color: AppTheme.border-light;
                border-width: 1px;

                ScrollView {
                    viewport-height: max(60px, root.compatible_params.length * 56px);

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;

                        if root.compatible_params.length == 0: CjkText {
                            text: "无兼容超参数（类型不匹配）";
                            color: AppTheme.text-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }

                        for hp in root.compatible_params: Rectangle {
                            height: 44px;
                            background: root.current_binding == hp.name ? #5b21b620 : AppTheme.surface-overlay;
                            border-radius: 6px;
                            border-width: root.current_binding == hp.name ? 2px : 1px;
                            border-color: root.current_binding == hp.name ? #7c3aed : AppTheme.border;

                            TouchArea {
                                clicked => { root.bind(hp.name); }
                            }

                            HorizontalLayout {
                                padding: 10px;
                                spacing: 8px;

                                CjkText {
                                    text: hp.name;
                                    font-size: 13px;
                                    font-weight: 700;
                                    color: root.current_binding == hp.name ? #a78bfa : AppTheme.text-primary;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: AppTheme.category-bg;
                                        border-radius: 4px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 2px; padding-bottom: 2px;
                                            CjkText {
                                                text: hp.data_type;
                                                font-size: 10px;
                                                color: AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                if hp.value != "": VerticalLayout {
                                    alignment: center;
                                    CjkText {
                                        text: hp.data_type == "Password" ? "= ****" : "= " + hp.value;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            CjkButton {
                text: "取消";
                clicked => { root.close(); }
            }
        }
    }
}