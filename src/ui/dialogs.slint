export component NodeSelector inherits Rectangle {
    in property <[NodeTypeVm]> node_types;
    in property <[string]> categories;
    callback add_node(string);
    callback close();
    callback filter(string, string);

    property <string> current_search: "";
    property <string> current_category: "";
    property <bool> show_help_panel: false;
    property <string> help_type_id: "";
    property <string> help_display_name: "";
    property <string> help_category: "";
    property <string> help_description: "";
    property <[PortHelpVm]> help_input_ports;
    property <[PortHelpVm]> help_output_ports;

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.show_help_panel ? 1080px : 700px;
        height: 600px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        HorizontalLayout {
            padding: 0;
            spacing: 0;

            // ── LEFT: node list panel ──
            VerticalBox {
                width: 680px;
                padding: 16px;
                spacing: 12px;

                CjkText {
                    text: "选择节点类型";
                    font-size: 18px;
                    color: AppTheme.text-primary;
                    horizontal-alignment: center;
                    height: 30px;
                }

                VerticalBox {
                    spacing: 8px;

                    HorizontalBox {
                        height: 50px;
                        CjkText {
                            text: "搜索:";
                            vertical-alignment: center;
                            width: 50px;
                            color: AppTheme.text-secondary;
                        }
                        LineEdit {
                            height: 35px;
                            placeholder-text: "输入名称、类型、分类或描述...";
                            edited(text) => {
                                root.current_search = text;
                                root.filter(root.current_search, root.current_category);
                            }
                        }
                    }

                    HorizontalBox {
                        height: 50px;
                        CjkText {
                            text: "分类:";
                            vertical-alignment: center;
                            width: 50px;
                            color: AppTheme.text-secondary;
                        }
                        ScrollView {
                            viewport-height: 30px;
                            height: 40px;
                            HorizontalLayout {
                                spacing: 8px;
                                padding-right: 8px;
                                alignment: start;

                                Rectangle {
                                    width: 60px;
                                    height: 30px;
                                    border-radius: 4px;
                                    background: root.current_category == "" ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            root.current_category = "";
                                            root.filter(root.current_search, root.current_category);
                                        }
                                    }

                                    CjkText {
                                        text: "全部";
                                        color: root.current_category == "" ? AppTheme.category-text-selected : AppTheme.category-text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 12px;
                                    }
                                }

                                for category in root.categories : Rectangle {
                                    width: 80px;
                                    height: 30px;
                                    border-radius: 4px;
                                    background: root.current_category == category ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            root.current_category = category;
                                            root.filter(root.current_search, root.current_category);
                                        }
                                    }

                                    CjkText {
                                        text: category;
                                        color: root.current_category == category ? AppTheme.category-text-selected : AppTheme.category-text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 12px;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    background: AppTheme.background;
                    border-radius: 6px;
                    border-color: AppTheme.border-light;
                    border-width: 1px;

                    ScrollView {
                        viewport-width: parent.width - 20px;
                        viewport-height: root.node_types.length * 100px;

                        VerticalBox {
                            padding: 8px;
                            spacing: 8px;
                            alignment: start;

                            for node_type in root.node_types: Rectangle {
                                height: 80px;
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: root.show_help_panel && root.help_type_id == node_type.type_id ? 2px : 1px;
                                border-color: root.show_help_panel && root.help_type_id == node_type.type_id ? AppTheme.selection : AppTheme.border;

                                TouchArea {
                                    clicked => {
                                        root.add_node(node_type.type_id);
                                        root.close();
                                    }
                                }

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        CjkText {
                                            text: node_type.display_name;
                                            font-size: 16px;
                                            color: AppTheme.text-primary;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;

                                                HorizontalLayout {
                                                    padding-left: 6px;
                                                    padding-right: 6px;
                                                    padding-top: 2px;
                                                    padding-bottom: 2px;
                                                    CjkText {
                                                        text: node_type.category;
                                                        font-size: 11px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    CjkText {
                                        text: node_type.description;
                                        font-size: 13px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                        vertical-alignment: top;
                                        overflow: elide;
                                    }
                                }

                                // "?" help button — top-right corner, declared last so it's on top
                                Rectangle {
                                    x: parent.width - self.width - 6px;
                                    y: 6px;
                                    width: 22px;
                                    height: 22px;
                                    background: root.show_help_panel && root.help_type_id == node_type.type_id
                                        ? AppTheme.category-bg-selected : AppTheme.category-bg;
                                    border-radius: 11px;
                                    border-width: 1px;
                                    border-color: AppTheme.border-light;

                                    TouchArea {
                                        clicked => {
                                            if root.show_help_panel && root.help_type_id == node_type.type_id {
                                                root.show_help_panel = false;
                                            } else {
                                                root.help_type_id = node_type.type_id;
                                                root.help_display_name = node_type.display_name;
                                                root.help_category = node_type.category;
                                                root.help_description = node_type.description;
                                                root.help_input_ports = node_type.input_ports;
                                                root.help_output_ports = node_type.output_ports;
                                                root.show_help_panel = true;
                                            }
                                        }
                                    }

                                    CjkText {
                                        text: "?";
                                        color: root.show_help_panel && root.help_type_id == node_type.type_id
                                            ? AppTheme.category-text-selected : AppTheme.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalBox {
                    alignment: center;
                    CjkButton {
                        text: "取消";
                        clicked => { root.close(); }
                    }
                }
            }            // ── RIGHT: help panel (only visible when show_help_panel) ──
            if root.show_help_panel: Rectangle {
                width: 380px;
                background: AppTheme.surface;

                // Left-edge separator
                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 1px;
                    height: parent.height;
                    background: AppTheme.border;
                }

                VerticalBox {
                    padding: 16px;
                    spacing: 10px;

                    // Title row
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            CjkText {
                                text: "节点帮助";
                                font-size: 14px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                background: AppTheme.category-bg;
                                border-radius: 11px;
                                border-width: 1px;
                                border-color: AppTheme.border-light;
                                TouchArea {
                                    clicked => { root.show_help_panel = false; }
                                }
                                CjkText {
                                    text: "×";
                                    color: AppTheme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 14px;
                                    font-weight: 700;
                                }
                            }
                        }
                    }

                    // Node name + category badge
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            CjkText {
                                text: root.help_display_name;
                                font-size: 18px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                background: AppTheme.category-bg;
                                border-radius: 4px;
                                HorizontalLayout {
                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                    CjkText {
                                        text: root.help_category;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                    }
                                }
                            }
                        }
                    }

                    // Description
                    CjkText {
                        text: root.help_description;
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                        wrap: word-wrap;
                    }

                    // Separator
                    Rectangle {
                        height: 1px;
                        background: AppTheme.border;
                    }

                    // Ports scroll area
                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 8px;
                            padding: 0;
                            alignment: start;

                            if root.help_input_ports.length > 0: CjkText {
                                text: "输入端口";
                                font-size: 12px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                                height: 20px;
                            }

                            for port in root.help_input_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 3px;

                                    HorizontalLayout {
                                        spacing: 5px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 11px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        if port.required: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: #b3440020;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: "必填";
                                                        font-size: 10px;
                                                        color: AppTheme.danger;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if root.help_output_ports.length > 0: Rectangle {
                                height: 10px;
                            }

                            if root.help_output_ports.length > 0: CjkText {
                                text: "输出端口";
                                font-size: 12px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                                height: 20px;
                            }

                            for port in root.help_output_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 3px;

                                    HorizontalLayout {
                                        spacing: 5px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 11px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 3px;
                                                HorizontalLayout {
                                                    padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }

                                    if port.connection_text != "": CjkText {
                                        text: port.connection_text;
                                        font-size: 11px;
                                        color: AppTheme.primary;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
export component NodeHelpDialog inherits Rectangle {
    in property <NodeTypeVm> node_data;
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 680px;
        height: 560px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title row
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: root.node_data.display_name;
                        font-size: 20px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        background: AppTheme.category-bg;
                        border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px;
                            CjkText {
                                text: root.node_data.category;
                                font-size: 12px;
                                color: AppTheme.text-muted;
                            }
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: start;
                    Rectangle {
                        width: 26px;
                        height: 26px;
                        background: AppTheme.category-bg;
                        border-radius: 13px;
                        border-width: 1px;
                        border-color: AppTheme.border-light;
                        TouchArea {
                            clicked => { root.close(); }
                        }
                        CjkText {
                            text: "×";
                            color: AppTheme.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }
                }
            }

            // Description
            CjkText {
                text: root.node_data.description;
                font-size: 13px;
                color: AppTheme.text-secondary;
                wrap: word-wrap;
            }

            // Separator
            Rectangle {
                height: 1px;
                background: AppTheme.border;
            }

            // Ports area (Two columns)
            HorizontalLayout {
                vertical-stretch: 1;
                spacing: 20px;

                // Left column - Input ports
                VerticalLayout {
                    horizontal-stretch: 1;
                    if root.node_data.input_ports.length > 0: CjkText {
                        text: "输入端口";
                        font-size: 13px;
                        font-weight: 700;
                        color: AppTheme.text-secondary;
                        height: 28px;
                        vertical-alignment: center;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 8px;
                            padding: 0px;
                            padding-bottom: 12px;
                            alignment: start;

                            for port in root.node_data.input_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 12px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        if port.required: VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: #b3440020;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: "必填";
                                                        font-size: 10px;
                                                        color: AppTheme.danger;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }

                                    if port.connection_text != "": CjkText {
                                        text: port.connection_text;
                                        font-size: 11px;
                                        color: AppTheme.primary;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }

                // Right column - Output ports
                VerticalLayout {
                    horizontal-stretch: 1;
                    if root.node_data.output_ports.length > 0: CjkText {
                        text: "输出端口";
                        font-size: 13px;
                        font-weight: 700;
                        color: AppTheme.text-secondary;
                        height: 28px;
                        vertical-alignment: center;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 8px;
                            padding: 0px;
                            padding-bottom: 12px;
                            alignment: start;

                            for port in root.node_data.output_ports: Rectangle {
                                background: AppTheme.surface-overlay;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: AppTheme.border;

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        CjkText {
                                            text: port.name;
                                            font-size: 12px;
                                            font-weight: 700;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                background: AppTheme.category-bg;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px;
                                                    CjkText {
                                                        text: port.data_type;
                                                        font-size: 10px;
                                                        color: AppTheme.text-muted;
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if port.description != "": CjkText {
                                        text: port.description;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }

                                    if port.connection_text != "": CjkText {
                                        text: port.connection_text;
                                        font-size: 11px;
                                        color: AppTheme.primary;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}


export component HyperParameterManagerDialog inherits Rectangle {
    in property <[HyperParameterVm]> hyperparameters;
    in property <[string]> groups;
    callback add(string, string, bool, string, string);   // name, data_type, required, description, group
    callback select_group(string);
    callback open_group_manager();
    callback delete(string);                       // name
    callback set_value(string, string);            // name, value
    callback toggle_required(string);              // name
    callback close();

    in-out property <string> current_group: "default";
    property <string> new_name: "";
    property <string> new_type: "String";
    property <bool> new_required: false;
    property <string> new_description: "";

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 680px;
        height: 560px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title row
            HorizontalLayout {
                spacing: 12px;
                CjkText {
                    text: "超参数管理";
                    font-size: 18px;
                    font-weight: 700;
                    color: AppTheme.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                ComboBox {
                    width: 120px;
                    height: 30px;
                    model: root.groups;
                    current-value: root.current_group;
                    selected(value) => {
                        root.current_group = value;
                        root.select_group(value);
                    }
                }
                CjkButton {
                    text: "分组管理";
                    clicked => { root.open_group_manager(); }
                }
                Rectangle {
                    width: 26px;
                    height: 26px;
                    background: AppTheme.category-bg;
                    border-radius: 13px;
                    border-width: 1px;
                    border-color: AppTheme.border-light;
                    TouchArea { clicked => { root.close(); } }
                    CjkText {
                        text: "×";
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }
            }

            // Existing hyperparameters list
            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.background;
                border-radius: 6px;
                border-color: AppTheme.border-light;
                border-width: 1px;

                ScrollView {
                    viewport-height: max(100px, root.hyperparameters.length * 64px);

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;

                        if root.hyperparameters.length == 0: CjkText {
                            text: "暂无超参数";
                            color: AppTheme.text-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }

                        for hp in root.hyperparameters: Rectangle {
                            visible: hp.group == root.current_group;
                            height: 52px;
                            background: AppTheme.surface-overlay;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: AppTheme.border;

                            HorizontalLayout {
                                padding: 8px;
                                spacing: 8px;

                                // Name badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: #5b21b620;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: #7c3aed40;
                                        width: 100px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.name;
                                                font-size: 11px;
                                                font-weight: 700;
                                                color: #a78bfa;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }

                                // Type badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: AppTheme.category-bg;
                                        border-radius: 4px;
                                        width: 60px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.data_type;
                                                font-size: 10px;
                                                color: AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                // Value editor
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    if hp.data_type != "Boolean" && hp.data_type != "Password": LineEdit {
                                        height: 28px;
                                        text: hp.value;
                                        placeholder-text: "输入默认值";
                                        edited(text) => {
                                            root.set_value(hp.name, text);
                                        }
                                    }
                                    if hp.data_type == "Password": LineEdit {
                                        height: 28px;
                                        input-type: password;
                                        text: hp.value;
                                        placeholder-text: "输入密码";
                                        edited(text) => {
                                            root.set_value(hp.name, text);
                                        }
                                    }
                                    if hp.data_type == "Boolean": HorizontalLayout {
                                        alignment: start;
                                        spacing: 4px;
                                        CheckBox {
                                            checked: hp.value == "true";
                                            toggled => {
                                                root.set_value(hp.name, self.checked ? "true" : "false");
                                            }
                                        }
                                        CjkText {
                                            text: hp.value == "true" ? "true" : "false";
                                            color: AppTheme.text-secondary;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Required badge (clickable toggle)
                                VerticalLayout {
                                    alignment: center;
                                    width: 56px;
                                    Rectangle {
                                        background: hp.required ? #b3440020 : AppTheme.category-bg;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: hp.required ? #b3440040 : AppTheme.border-light;
                                        TouchArea {
                                            clicked => { root.toggle_required(hp.name); }
                                        }
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 4px; padding-bottom: 4px;
                                            CjkText {
                                                text: hp.required ? "必填" : "可选";
                                                font-size: 10px;
                                                color: hp.required ? AppTheme.danger : AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                // Delete button
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 24px;
                                        height: 24px;
                                        background: AppTheme.danger-bg;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: AppTheme.danger;
                                        TouchArea {
                                            clicked => { root.delete(hp.name); }
                                        }
                                        CjkText {
                                            text: "×";
                                            color: AppTheme.danger;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Separator
            Rectangle { height: 1px; background: AppTheme.border; }

            // Add new hyperparameter form
            VerticalLayout {
                spacing: 8px;

                CjkText {
                    text: "新增超参数";
                    font-size: 13px;
                    font-weight: 700;
                    color: AppTheme.text-secondary;
                }

                HorizontalLayout {
                    spacing: 8px;

                    LineEdit {
                        horizontal-stretch: 1;
                        height: 32px;
                        placeholder-text: "参数名称";
                        text <=> root.new_name;
                    }

                    ComboBox {
                        width: 90px;
                        height: 32px;
                        model: ["String", "Integer", "Float", "Boolean", "Password"];
                        current-value: root.new_type;
                        selected(val) => { root.new_type = val; }
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        alignment: center;
                        width: 60px;
                        CheckBox {
                            checked: root.new_required;
                            toggled => { root.new_required = self.checked; }
                        }
                        CjkText {
                            text: "必填";
                            color: AppTheme.text-secondary;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }

                    CjkButton {
                        text: "添加";
                        clicked => {
                            if (root.new_name != "") {
                                root.add(root.new_name, root.new_type, root.new_required, root.new_description, root.current_group == "" ? "default" : root.current_group);
                                root.new_name = "";
                                root.new_required = false;
                                root.new_description = "";
                            }
                        }
                    }
                }
            }
        }
    }
}

export component GroupManagerDialog inherits Rectangle {
    in property <[string]> groups;
    in-out property <string> current_group: "default";
    callback select_group(string);
    callback create_group(string);
    callback rename_group(string, string);
    callback delete_group(string);
    callback close();

    property <string> new_group_name: "";

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 520px;
        height: 460px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 12px;
                CjkText {
                    text: "分组管理";
                    font-size: 18px;
                    font-weight: 700;
                    color: AppTheme.text-primary;
                    horizontal-stretch: 1;
                }
                Rectangle {
                    width: 26px;
                    height: 26px;
                    background: AppTheme.category-bg;
                    border-radius: 13px;
                    border-width: 1px;
                    border-color: AppTheme.border-light;
                    TouchArea { clicked => { root.close(); } }
                    CjkText {
                        text: "×";
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.background;
                border-radius: 6px;
                border-color: AppTheme.border-light;
                border-width: 1px;

                ScrollView {
                    viewport-height: max(120px, root.groups.length * 60px);

                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;

                        for group in root.groups: Rectangle {
                            height: 52px;
                            background: root.current_group == group ? AppTheme.surface : AppTheme.surface-overlay;
                            border-radius: 6px;
                            border-width: root.current_group == group ? 2px : 1px;
                            border-color: root.current_group == group ? AppTheme.selection : AppTheme.border;

                            HorizontalLayout {
                                padding: 8px;
                                spacing: 8px;

                                LineEdit {
                                    horizontal-stretch: 1;
                                    height: 32px;
                                    text: group;
                                    enabled: group != "default";
                                    edited(text) => {
                                        root.rename_group(group, text);
                                    }
                                }

                                CjkButton {
                                    text: "选择";
                                    clicked => {
                                        root.current_group = group;
                                        root.select_group(group);
                                    }
                                }

                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    background: group == "default" ? AppTheme.category-bg : AppTheme.danger-bg;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: group == "default" ? AppTheme.border-light : AppTheme.danger;
                                    TouchArea {
                                        enabled: group != "default";
                                        clicked => { root.delete_group(group); }
                                    }
                                    CjkText {
                                        text: "×";
                                        color: group == "default" ? AppTheme.text-muted : AppTheme.danger;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 14px;
                                        font-weight: 700;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;

                LineEdit {
                    horizontal-stretch: 1;
                    height: 32px;
                    placeholder-text: "新分组名称";
                    text <=> root.new_group_name;
                }

                CjkButton {
                    text: "新建分组";
                    clicked => {
                        if (root.new_group_name != "") {
                            root.create_group(root.new_group_name);
                            root.new_group_name = "";
                        }
                    }
                }
            }
        }
    }
}


export component PortBindHyperparamDialog inherits Rectangle {
    in property <[HyperParameterVm]> compatible_params;
    in property <string> current_binding;
    in property <string> port_name;
    callback bind(string);     // name
    callback clear_binding();
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 480px;
        height: 420px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // Title
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: "绑定超参数";
                        font-size: 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }
                    CjkText {
                        text: "端口: " + root.port_name;
                        font-size: 12px;
                        color: AppTheme.text-muted;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 26px;
                    height: 26px;
                    background: AppTheme.category-bg;
                    border-radius: 13px;
                    border-width: 1px;
                    border-color: AppTheme.border-light;
                    TouchArea { clicked => { root.close(); } }
                    CjkText {
                        text: "×";
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }
            }

            // Current binding info
            if root.current_binding != "": HorizontalLayout {
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    CjkText {
                        text: "当前绑定: " + root.current_binding;
                        font-size: 12px;
                        color: #a78bfa;
                    }
                }
                CjkDeleteButton {
                    text: "清除绑定";
                    clicked => { root.clear_binding(); }
                }
            }

            // Compatible params list
            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.background;
                border-radius: 6px;
                border-color: AppTheme.border-light;
                border-width: 1px;

                ScrollView {
                    viewport-height: max(60px, root.compatible_params.length * 56px);

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;

                        if root.compatible_params.length == 0: CjkText {
                            text: "无兼容超参数（类型不匹配）";
                            color: AppTheme.text-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }

                        for hp in root.compatible_params: Rectangle {
                            height: 44px;
                            background: root.current_binding == hp.name ? #5b21b620 : AppTheme.surface-overlay;
                            border-radius: 6px;
                            border-width: root.current_binding == hp.name ? 2px : 1px;
                            border-color: root.current_binding == hp.name ? #7c3aed : AppTheme.border;

                            TouchArea {
                                clicked => { root.bind(hp.name); }
                            }

                            HorizontalLayout {
                                padding: 10px;
                                spacing: 8px;

                                CjkText {
                                    text: hp.name;
                                    font-size: 13px;
                                    font-weight: 700;
                                    color: root.current_binding == hp.name ? #a78bfa : AppTheme.text-primary;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        background: AppTheme.category-bg;
                                        border-radius: 4px;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            padding-top: 2px; padding-bottom: 2px;
                                            CjkText {
                                                text: hp.data_type;
                                                font-size: 10px;
                                                color: AppTheme.text-muted;
                                            }
                                        }
                                    }
                                }

                                if hp.value != "": VerticalLayout {
                                    alignment: center;
                                    CjkText {
                                        text: hp.data_type == "Password" ? "= ****" : "= " + hp.value;
                                        font-size: 11px;
                                        color: AppTheme.text-muted;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            CjkButton {
                text: "取消";
                clicked => { root.close(); }
            }
        }
    }
}

export component LogHistoryDialog inherits Rectangle {
    in property <[LogEntryVm]> entries;
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 900px;
        height: parent.height - 80px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {} // block backdrop click-through

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // ── Title bar ──
            HorizontalLayout {
                spacing: 0px;

                CjkText {
                    text: "运行日志";
                    font-size: 18px;
                    font-weight: 700;
                    color: AppTheme.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                close-btn := Rectangle {
                    width: 30px;
                    height: 30px;
                    border-radius: 6px;
                    background: close-ta.has-hover ? AppTheme.surface : transparent;

                    close-ta := TouchArea {
                        clicked => { root.close(); }
                    }

                    CjkText {
                        text: "×";
                        color: AppTheme.text-muted;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }
                }
            }

            // Divider
            Rectangle {
                height: 1px;
                background: AppTheme.border;
            }

            // ── Scrollable log list ──
            ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 2px;
                    padding: 2px;
                    alignment: start;

                    for entry in root.entries: Rectangle {
                        border-radius: 3px;
                        background: AppTheme.surface;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            padding-top: 6px;
                            padding-bottom: 6px;
                            spacing: 8px;
                            alignment: start;

                            // Level badge — pinned to top of the row
                            VerticalLayout {
                                alignment: start;
                                padding-top: 1px;

                                Rectangle {
                                    width: 46px;
                                    height: 18px;
                                    border-radius: 3px;
                                    background:
                                        entry.level == "ERROR" ? #f44336 :
                                        entry.level == "WARN"  ? #ffc107 :
                                        entry.level == "INFO"  ? #4caf50 :
                                        entry.level == "DEBUG" ? #2196f3 :
                                        #9e9e9e;

                                    CjkText {
                                        text: entry.level;
                                        color: entry.level == "WARN" ? #000000 : #ffffff;
                                        font-size: 10px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: 100%;
                                        height: 100%;
                                    }
                                }
                            }

                            // Message — wraps freely
                            CjkText {
                                text: entry.message;
                                color: AppTheme.text-primary;
                                font-size: 12px;
                                vertical-alignment: top;
                                horizontal-stretch: 1;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }

            // ── Footer ──
            HorizontalLayout {
                alignment: center;

                CjkButton {
                    text: "关闭";
                    clicked => { root.close(); }
                }
            }
        }
    }
}

export component ToolEditorDialog inherits Rectangle {
    in property <[ToolDefinitionVm]> tools;
    in property <int> selected_tool_index: -1;
    callback select_tool(int);
    callback add_tool();
    callback delete_tool(int);
    callback set_tool_name(int, string);
    callback set_tool_description(int, string);
    callback add_param(int);
    callback delete_param(int, int);
    callback set_param_name(int, int, string);
    callback set_param_type(int, int, string);
    callback set_param_description(int, int, string);
    callback save();
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 980px;
        height: 640px;
        background: AppTheme.node-bg;
        border-radius: 12px;
        border-width: 2px;
        border-color: AppTheme.border;
        clip: true;

        TouchArea {}

        HorizontalLayout {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                width: 280px;
                background: AppTheme.surface;

                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 8px;

                        CjkText {
                            text: "Function Tools";
                            font-size: 18px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            horizontal-stretch: 1;
                        }

                        CjkButton {
                            text: "新增";
                            clicked => { root.add_tool(); }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: AppTheme.background;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: AppTheme.border-light;

                        ScrollView {
                            viewport-height: max(80px, root.tools.length * 64px);

                            VerticalLayout {
                                padding: 8px;
                                spacing: 8px;
                                alignment: start;

                                if root.tools.length == 0: CjkText {
                                    text: "暂无 Tool\n点击新增开始配置";
                                    color: AppTheme.text-muted;
                                    font-size: 13px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                    width: 220px;
                                }

                                for tool[i] in root.tools: Rectangle {
                                    height: 56px;
                                    background: root.selected_tool_index == i ? AppTheme.surface-overlay : AppTheme.node-bg;
                                    border-radius: 6px;
                                    border-width: root.selected_tool_index == i ? 2px : 1px;
                                    border-color: root.selected_tool_index == i ? AppTheme.selection : AppTheme.border;

                                    TouchArea {
                                        clicked => { root.select_tool(i); }
                                    }

                                    HorizontalLayout {
                                        padding: 8px;
                                        spacing: 8px;

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;

                                            CjkText {
                                                text: tool.name == "" ? "未命名 Tool" : tool.name;
                                                font-size: 13px;
                                                font-weight: 700;
                                                color: AppTheme.text-primary;
                                                overflow: elide;
                                            }

                                            CjkText {
                                                text: tool.description == "" ? "暂无描述" : tool.description;
                                                font-size: 11px;
                                                color: AppTheme.text-muted;
                                                overflow: elide;
                                            }
                                        }

                                        Rectangle {
                                            width: 24px;
                                            height: 24px;
                                            background: AppTheme.danger-bg;
                                            border-radius: 4px;
                                            border-width: 1px;
                                            border-color: AppTheme.danger;

                                            TouchArea {
                                                clicked => { root.delete_tool(i); }
                                            }

                                            CjkText {
                                                text: "×";
                                                color: AppTheme.danger;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                font-size: 14px;
                                                font-weight: 700;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: AppTheme.border;
            }

            Rectangle {
                horizontal-stretch: 1;
                background: AppTheme.node-bg;

                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;

                    HorizontalLayout {
                        spacing: 12px;

                        CjkText {
                            text: "编辑 Tool";
                            font-size: 18px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            width: 26px;
                            height: 26px;
                            background: AppTheme.category-bg;
                            border-radius: 13px;
                            border-width: 1px;
                            border-color: AppTheme.border-light;
                            TouchArea { clicked => { root.close(); } }
                            CjkText {
                                text: "×";
                                color: AppTheme.text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 16px;
                                font-weight: 700;
                            }
                        }
                    }

                    if root.selected_tool_index < 0 || root.selected_tool_index >= root.tools.length: Rectangle {
                        vertical-stretch: 1;
                        background: AppTheme.background;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: AppTheme.border-light;

                        CjkText {
                            text: "请选择左侧 Tool，或点击“新增”创建新的 Tool。";
                            color: AppTheme.text-muted;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    for tool[i] in root.tools: Rectangle {
                        visible: i == root.selected_tool_index;
                        background: transparent;
                        border-width: 0px;
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 10px;
                            vertical-stretch: 1;

                            CjkText {
                                text: "基础信息";
                                font-size: 13px;
                                font-weight: 700;
                                color: AppTheme.text-secondary;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                CjkText {
                                    text: "名称";
                                    width: 50px;
                                    color: AppTheme.text-secondary;
                                    vertical-alignment: center;
                                }
                                LineEdit {
                                    horizontal-stretch: 1;
                                    height: 32px;
                                    text: tool.name;
                                    placeholder-text: "例如 search_docs";
                                    edited(text) => { root.set_tool_name(i, text); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                CjkText {
                                    text: "描述";
                                    width: 50px;
                                    color: AppTheme.text-secondary;
                                    vertical-alignment: center;
                                }
                                LineEdit {
                                    horizontal-stretch: 1;
                                    height: 32px;
                                    text: tool.description;
                                    placeholder-text: "给 LLM 看的工具用途描述";
                                    edited(text) => { root.set_tool_description(i, text); }
                                }
                            }

                            Rectangle { height: 1px; background: AppTheme.border; }

                            HorizontalLayout {
                                spacing: 8px;

                                CjkText {
                                    text: "参数列表";
                                    font-size: 13px;
                                    font-weight: 700;
                                    color: AppTheme.text-secondary;
                                    horizontal-stretch: 1;
                                }

                                CjkButton {
                                    text: "新增参数";
                                    clicked => { root.add_param(i); }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                                background: AppTheme.background;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: AppTheme.border-light;

                                ScrollView {
                                    viewport-height: max(80px, tool.params.length * 78px);

                                    VerticalLayout {
                                        padding: 8px;
                                        spacing: 8px;
                                        alignment: start;

                                        if tool.params.length == 0: CjkText {
                                            text: "该 Tool 还没有参数。";
                                            color: AppTheme.text-muted;
                                            font-size: 13px;
                                        }

                                        for param[j] in tool.params: Rectangle {
                                            height: 70px;
                                            background: AppTheme.surface-overlay;
                                            border-radius: 6px;
                                            border-width: 1px;
                                            border-color: AppTheme.border;

                                            VerticalLayout {
                                                padding: 8px;
                                                spacing: 8px;

                                                HorizontalLayout {
                                                    spacing: 8px;

                                                    LineEdit {
                                                        width: 180px;
                                                        height: 30px;
                                                        text: param.name;
                                                        placeholder-text: "参数名";
                                                        edited(text) => { root.set_param_name(i, j, text); }
                                                    }

                                                    ComboBox {
                                                        width: 100px;
                                                        height: 30px;
                                                        model: ["String", "Integer", "Float", "Boolean", "Json"];
                                                        current-value: param.data_type;
                                                        selected(value) => { root.set_param_type(i, j, value); }
                                                    }

                                                    LineEdit {
                                                        horizontal-stretch: 1;
                                                        height: 30px;
                                                        text: param.description;
                                                        placeholder-text: "参数描述";
                                                        edited(text) => { root.set_param_description(i, j, text); }
                                                    }

                                                    Rectangle {
                                                        width: 24px;
                                                        height: 24px;
                                                        background: AppTheme.danger-bg;
                                                        border-radius: 4px;
                                                        border-width: 1px;
                                                        border-color: AppTheme.danger;

                                                        TouchArea {
                                                            clicked => { root.delete_param(i, j); }
                                                        }

                                                        CjkText {
                                                            text: "×";
                                                            color: AppTheme.danger;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                            font-size: 14px;
                                                            font-weight: 700;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: end;
                        spacing: 10px;

                        CjkButton {
                            text: "取消";
                            clicked => { root.close(); }
                        }

                        CjkButton {
                            text: "保存";
                            clicked => { root.save(); }
                        }
                    }
                }
            }
        }
    }
}

export component FormatStringEditorDialog inherits Rectangle {
    in-out property <string> template_text;
    in property <[string]> variables;
    in property <[string]> autocomplete_suggestions;
    in property <bool> show_autocomplete;
    in property <int> autocomplete_selected_index: -1;
    callback text_changed(string, int);
    callback autocomplete_select(string);
    callback autocomplete_navigate(int);
    callback autocomplete_accept();
    callback save();
    callback cancel();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 900px;
        height: 550px;
        background: AppTheme.node-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;

        TouchArea {}

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            // Title
            CjkText {
                text: "编辑格式化文本";
                font-size: 16px;
                color: AppTheme.text-primary;
                font-weight: 700;
                horizontal-alignment: left;
            }

            // Main area: left variable list + right editor
            HorizontalLayout {
                spacing: 12px;
                vertical-stretch: 1;

                // Left panel: variable list
                Rectangle {
                    width: 180px;
                    background: AppTheme.surface;
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: AppTheme.border;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;

                        CjkText {
                            text: "变量列表";
                            font-size: 12px;
                            color: AppTheme.text-secondary;
                            font-weight: 600;
                            horizontal-alignment: left;
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            viewport-height: max(40px, root.variables.length * 34px);

                            VerticalLayout {
                                spacing: 4px;

                                for var in root.variables: Rectangle {
                                    height: 28px;
                                    background: AppTheme.primary-muted;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: AppTheme.primary;

                                    CjkText {
                                        text: "${" + var + "}";
                                        font-size: 11px;
                                        color: AppTheme.text-primary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        if root.variables.length == 0: CjkText {
                            text: "（暂无变量）";
                            font-size: 11px;
                            color: AppTheme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Right panel: text editor + autocomplete
                right_panel := Rectangle {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;
                    private property <length> caret_x: 0px;
                    private property <length> caret_y: 0px;
                    private property <length> caret_line_height: 20px;

                    VerticalLayout {
                        spacing: 4px;

                        CjkText {
                            text: "请输入字符串模板";
                            font-size: 11px;
                            color: AppTheme.text-secondary;
                            horizontal-alignment: left;
                        }

                        // Text editor
                        editor := Rectangle {
                            vertical-stretch: 1;
                            background: AppTheme.surface;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: AppTheme.border;

                            scroll := ScrollView {
                                x: 8px;
                                y: 8px;
                                width: parent.width - 16px;
                                height: parent.height - 16px;
                                viewport-width: self.visible-width;
                                viewport-height: max(self.visible-height, input.preferred-height);

                                input := TextInput {
                                    width: parent.visible-width;
                                    height: max(parent.visible-height, self.preferred-height);
                                    text <=> root.template_text;
                                    font-size: 13px;
                                    color: AppTheme.text-primary;
                                    selection-background-color: AppTheme.selection;
                                    selection-foreground-color: #ffffff;
                                    single-line: false;
                                    wrap: word-wrap;
                                    page-height: parent.visible-height;

                                    edited => {
                                        root.text_changed(self.text, self.cursor-position_byte-offset);
                                    }

                                    key-pressed(event) => {
                                        if (root.show_autocomplete && root.autocomplete_suggestions.length > 0) {
                                            if (event.text == Key.UpArrow) {
                                                root.autocomplete_navigate(-1);
                                                return accept;
                                            } else if (event.text == Key.DownArrow) {
                                                root.autocomplete_navigate(1);
                                                return accept;
                                            } else if (event.text == Key.Tab) {
                                                root.autocomplete_accept();
                                                return accept;
                                            }
                                        }
                                        return reject;
                                    }

                                    cursor-position-changed(cpos) => {
                                        if (cpos.y + scroll.viewport-y < 12px) {
                                            scroll.viewport-y = min(0px, max(parent.visible-height - self.height, -cpos.y + 12px));
                                        } else if (cpos.y + scroll.viewport-y > parent.visible-height - 12px - right_panel.caret_line_height) {
                                            scroll.viewport-y = min(0px, max(parent.visible-height - self.height, parent.visible-height - cpos.y - 12px - right_panel.caret_line_height));
                                        }

                                        right_panel.caret_x = scroll.x + cpos.x + scroll.viewport-x;
                                        right_panel.caret_y = scroll.y + cpos.y + scroll.viewport-y;

                                        root.text_changed(self.text, self.cursor-position_byte-offset);
                                    }
                                }
                            }

                            if root.show_autocomplete && root.autocomplete_suggestions.length > 0: Rectangle {
                                width: min(editor.width - 8px, 260px);
                                height: min(root.autocomplete_suggestions.length * 30px + 8px, 160px);
                                x: max(4px, min(editor.width - self.width - 4px, right_panel.caret_x));
                                y: max(4px, min(editor.height - self.height - 4px, right_panel.caret_y + right_panel.caret_line_height + 2px));
                                background: AppTheme.node-bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: AppTheme.primary;

                                ScrollView {
                                    viewport-height: root.autocomplete_suggestions.length * 30px;

                                    VerticalLayout {
                                        padding: 4px;
                                        spacing: 2px;

                                        for suggestion[i] in root.autocomplete_suggestions: Rectangle {
                                            height: 28px;
                                            border-radius: 3px;

                                            states [
                                                selected when i == root.autocomplete_selected_index: {
                                                    background: AppTheme.primary-muted;
                                                }
                                                hovered when ta.has-hover && i != root.autocomplete_selected_index: {
                                                    background: AppTheme.surface;
                                                }
                                            ]

                                            ta := TouchArea {
                                                clicked => { root.autocomplete_select(suggestion); }
                                            }

                                            CjkText {
                                                x: 8px;
                                                text: suggestion;
                                                font-size: 12px;
                                                color: AppTheme.text-primary;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Footer buttons
            HorizontalBox {
                alignment: center;
                spacing: 12px;

                CjkButton {
                    text: "取消";
                    clicked => { root.cancel(); }
                }

                CjkButton {
                    text: "保存";
                    clicked => { root.save(); }
                }
            }
        }
    }
}

export component JsonExtractEditorDialog inherits Rectangle {
    in property <[JsonExtractFieldVm]> fields;
    in property <int> selected_field_index: -1;
