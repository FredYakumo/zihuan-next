import { HorizontalBox, VerticalBox, ScrollView, LineEdit, CheckBox, ComboBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { JsonExtractFieldVm, NodeTypeVm, PortHelpVm, HyperParameterVm, LogEntryVm, ToolDefinitionVm, ValidationIssueVm } from "types.slint";
import { CjkButton, CjkDeleteButton, CjkText } from "components/buttons.slint";

export component ValidationFixDialog inherits Rectangle {
    in property <[ValidationIssueVm]> issues;
    callback confirm();
    callback cancel();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 560px;
        height: 460px;
        background: AppTheme.node-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            CjkText {
                text: "节点图存在兼容性问题";
                font-size: 16px;
                color: AppTheme.text-primary;
                font-weight: 700;
                horizontal-alignment: left;
            }

            CjkText {
                text: "检测到以下节点定义与当前程序不符，是否自动修复？\n修复仅在内存中生效，不会保存文件。";
                font-size: 12px;
                color: AppTheme.text-secondary;
                wrap: word-wrap;
                horizontal-alignment: left;
            }

            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.surface;
                border-radius: 4px;
                border-width: 1px;
                border-color: AppTheme.border;

                ScrollView {
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        for issue in root.issues: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Rectangle {
                                width: 48px;
                                height: 20px;
                                border-radius: 3px;
                                background: issue.severity == "error" ? AppTheme.error-icon-bg : #b07800;

                                CjkText {
                                    text: issue.severity == "error" ? "错误" : "警告";
                                    font-size: 11px;
                                    color: AppTheme.text-on-primary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }
                            }

                            CjkText {
                                text: issue.message;
                                font-size: 12px;
                                color: AppTheme.text-primary;
                                wrap: word-wrap;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            HorizontalBox {
                alignment: center;
                spacing: 12px;

                CjkButton {
                    text: "自动修复并打开";
                    clicked => { root.confirm(); }
                }

                CjkButton {
                    text: "取消";
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}

export component ErrorDialog inherits Rectangle {
    in property <string> error_message;
    callback close();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 800px;
        height: 200px;
        background: AppTheme.error-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.error-border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 16px;

                Rectangle {
                    width: 48px;

                    VerticalLayout {
                        alignment: start;

                        Rectangle {
                            width: 36px;
                            height: 36px;
                            border-radius: 18px;
                            background: AppTheme.error-icon-bg;

                            CjkText {
                                text: "!";
                                font-size: 24px;
                                color: AppTheme.text-on-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-weight: 700;
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 8px;

                    CjkText {
                        text: "节点图执行失败";
                        font-size: 16px;
                        color: AppTheme.error-title;
                        font-weight: 700;
                        horizontal-alignment: left;
                    }

                    Rectangle {
                        background: AppTheme.error-message-bg;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: AppTheme.error-message-border;

                        ScrollView {
                            VerticalLayout {
                                padding: 10px;

                                CjkText {
                                    text: root.error_message;
                                    font-size: 12px;
                                    color: AppTheme.error-message-text;
                                    wrap: word-wrap;
                                    horizontal-alignment: left;
                                }
                            }
                        }
                    }
                }
            }

            HorizontalBox {
                alignment: center;

                CjkButton {
                    text: "确定";
                    clicked => { root.close(); }
                }
            }
        }
    }
}

export component SaveConfirmDialog inherits Rectangle {
    in property <string> message;
    callback save();
    callback discard();
    callback cancel();

    background: AppTheme.overlay-mask;

    TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 800px;
        height: 200px;
        background: AppTheme.node-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            CjkText {
                text: root.message;
                font-size: 16px;
                color: AppTheme.text-primary;
                font-weight: 700;
                horizontal-alignment: left;
            }

            HorizontalBox {
                alignment: center;
                spacing: 12px;

                CjkButton {
                    text: "保存";
                    clicked => { root.save(); }
                }

                CjkDeleteButton {
                    text: "不保存";
                    clicked => { root.discard(); }
                }

                CjkButton {
                    text: "取消";
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}

