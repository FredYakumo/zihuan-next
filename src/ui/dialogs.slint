                            }

                            HorizontalLayout {
                                spacing: 8px;
                                CjkText {
                                    text: "类型";
                                    width: 60px;
                                    color: AppTheme.text-secondary;
                                    vertical-alignment: center;
                                }
                                ComboBox {
                                    width: 140px;
                                    height: 32px;
                                    model: ["String", "Integer", "Float", "Boolean", "Json"];
                                    current-value: field.data_type;
                                    selected(value) => { root.set_field_type(i, value); }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                                background: AppTheme.background;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: AppTheme.border-light;

                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 8px;

                                    CjkText {
                                        text: "保存后会按当前字段列表动态重建输出端口。";
                                        font-size: 13px;
                                        color: AppTheme.text-primary;
                                        wrap: word-wrap;
                                    }

                                    CjkText {
                                        text: "字段名同时作为 JSON 对象的键名和节点输出端口名。";
                                        font-size: 12px;
                                        color: AppTheme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: end;
                        spacing: 10px;

                        CjkButton {
                            text: "取消";
                            clicked => { root.close(); }
                        }

                        CjkButton {
                            text: "保存";
                            clicked => { root.save(); }
                        }
                    }
                }
            }
        }
    }
}
