                    for field[i] in root.fields: Rectangle {
                        visible: i == root.selected_field_index;
                        background: transparent;
                        border-width: 0px;
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 12px;
                            vertical-stretch: 1;

                            CjkText {
                                text: "字段信息";
                                font-size: 13px;
                                font-weight: 700;
