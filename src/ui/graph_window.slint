import { VerticalBox } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { EdgeCornerVm, EdgeLabelVm, EdgeSegmentVm, EdgeVm, FunctionPortVm, GraphVariableVm, GridLineVm, HyperParameterVm, JsonExtractFieldVm, LogEntryVm, NodeTypeVm, NodeVm, ToolDefinitionVm, ValidationIssueVm } from "types.slint";
import { CjkButton, CjkDeleteButton, CjkRunButton, CjkText } from "components/buttons.slint";
import { MenuBarItem, MenuItemRow } from "components/menubar.slint";
import { TabItem } from "components/tabs.slint";
import { GraphCanvas } from "components/graph_canvas.slint";
import { LogOverlay } from "components/log_overlay.slint";
import { ErrorDialog, FormatStringEditorDialog, FunctionEditorDialog, GroupManagerDialog, HyperParameterManagerDialog, JsonExtractEditorDialog, LogHistoryDialog, NodeHelpDialog, NodeSelector, OverwriteConfirmDialog, PortBindHyperparamDialog, PortBindVariableDialog, RunningConfirmDialog, SaveConfirmDialog, ToolEditorDialog, ValidationFixDialog, VariableManagerDialog } from "dialogs.slint";

export component NodeGraphWindow inherits Window {
    in property <[NodeVm]> nodes;
    in property <[EdgeVm]> edges;
    in property <[EdgeSegmentVm]> edge_segments;
    in property <[EdgeCornerVm]> edge_corners;
    in property <[EdgeLabelVm]> edge_labels;
    in property <[GridLineVm]> grid_lines;
    in property <float> grid_size: 20;
    in property <float> edge_thickness: 6;
    in property <string> connection_status: "";
    in property <string> current_file;
    in property <[string]> graph_tabs;
    in property <int> active_tab_index: 0;
    callback select_tab(int);
    callback new_tab();
    callback close_tab();
    in property <bool> show_node_selector: false;
    in property <[NodeTypeVm]> available_node_types;
    in property <[string]> node_categories;
    callback filter_nodes(string, string);
    in property <bool> drag_line_visible: false;
    in property <float> drag_line_from_x: 0;
    in property <float> drag_line_from_y: 0;
    in property <float> drag_line_to_x: 0;
    in property <float> drag_line_to_y: 0;
    in-out property <bool> dragging: false;
    in-out property <string> drag_from_node_id: "";
    in-out property <string> drag_from_port: "";
    in-out property <bool> drag_from_is_input: false;
    in-out property <float> canvas_pan_x: 0;
    in-out property <float> canvas_pan_y: 0;
    in-out property <float> canvas_zoom: 1.0;
    in property <float> canvas_viewport_width: canvas_container.width / 1px;
    in property <float> canvas_viewport_height: canvas_container.height / 1px;
    in property <int> selected_node_count: 0;
    in property <string> selected_edge_from_node: "";
    in property <string> selected_edge_from_port: "";
    in property <string> selected_edge_to_node: "";
    in property <string> selected_edge_to_port: "";
    in property <bool> box_selection_visible: false;
    in property <float> box_selection_x: 0;
    in property <float> box_selection_y: 0;
    in property <float> box_selection_width: 0;
    in property <float> box_selection_height: 0;
    in property <string> port_hint_text: "";
    in property <float> port_hint_x: 0;
    in property <float> port_hint_y: 0;
    in property <bool> show_port_hint: false;
    in property <bool> show_error_dialog: false;
    in property <string> error_dialog_message: "";
    in property <bool> show_validation_fix_dialog: false;
    in property <[ValidationIssueVm]> validation_issues;
    in property <bool> show_graph_context_menu: false;
    in property <float> graph_context_menu_x: 0;
    in property <float> graph_context_menu_y: 0;
    in property <string> graph_context_menu_mode: "";
    in property <bool> graph_context_menu_can_paste: false;
    callback validation_fix_confirm();
    callback validation_fix_cancel();
    callback hide_graph_context_menu();
    in-out property <bool> menu_open: false;
    in property <bool> show_in_window_menu: true;
    in property <bool> show_save_confirm: false;
    in property <string> save_confirm_message: "当前节点图未保存，是否保存？";
    callback save_confirm_save();
    callback save_confirm_discard();
    callback save_confirm_cancel();
    in property <bool> show_running_confirm: false;
    in property <string> running_confirm_message: "节点图正在运行，是否停止并关闭？";
    callback running_confirm_close();
    callback running_confirm_cancel();
    in property <bool> show_overwrite_confirm: false;
    in property <string> overwrite_confirm_message: "文件已存在，是否覆盖？";
    callback overwrite_confirm_overwrite();
    callback overwrite_confirm_cancel();
    in property <bool> show_node_help_dialog: false;
    in property <NodeTypeVm> node_help_data;
    callback show_node_help(string, string);
    callback hide_node_help();

    callback open_json();
    callback save_json();
    callback save_json_as();
    callback add_node(string);
    callback run_graph();
    callback stop_graph();
    in property <bool> is_graph_running: false;
    callback show_node_type_menu();
    callback hide_node_type_menu();
    callback show_error(string);
    callback hide_error();
    callback node_moved(string, float, float);
    callback node_move_finished(string, float, float);
    callback port_clicked(string, string, bool);
    callback pointer_moved(float, float);
    callback cancel_connect();
    callback node_pointer_down(string, bool);
    callback node_clicked(string, bool);
    callback node_right_clicked(string, float, float);
    callback edge_clicked(string, string, string, string);
    callback canvas_clicked();
    callback canvas_right_clicked(float, float, float, float);
    callback delete_selected();
    callback copy_selected_nodes();
    callback convert_selection_to_function_subgraph();
    callback paste_nodes_at_context();
    callback context_menu_new_node();
    callback auto_layout_graph();
    callback box_selection_start(float, float);
    callback box_selection_update(float, float);
    callback box_selection_end();
    callback inline_port_text_changed(string, string, string);
    callback inline_port_bool_changed(string, string, bool);
    callback message_list_add(string);
    callback message_list_insert(string, int);
    callback message_list_delete(string, int);
    callback message_list_move_up(string, int);
    callback message_list_move_down(string, int);
    callback message_list_cycle_role(string, int);
    callback message_list_set_content(string, int, string);
    callback qq_message_list_add(string);
    callback qq_message_list_insert(string, int);
    callback qq_message_list_cycle_type(string, int);
    callback qq_message_list_set_content(string, int, string);
    callback node_resized(string, float, float);
    callback node_resize_finished(string, float, float);
    callback edit_tools_clicked(string);
    callback edit_function_clicked(string);
    callback enter_function_subgraph_clicked(string);
    callback edit_format_string_clicked(string);
    callback edit_json_extract_clicked(string);
    callback set_variable_node_selected(string, string);

    // Hyperparameter system
    in property <[HyperParameterVm]> hyperparameters;
    in property <[GraphVariableVm]> graph_variables;
    in property <[string]> hyperparameter_groups;
    in-out property <string> selected_hyperparameter_group: "default";
    in property <bool> show_hyperparameter_manager: false;
    in property <bool> show_variable_manager: false;
    in property <bool> show_group_manager: false;
    in property <bool> show_port_bind_menu: false;
    in property <float> port_bind_menu_x: 0;
    in property <float> port_bind_menu_y: 0;
    in property <bool> show_port_bind_dialog: false;
    in property <bool> show_port_variable_bind_dialog: false;
    in property <[HyperParameterVm]> port_bind_compatible_params;
    in property <[GraphVariableVm]> port_bind_compatible_variables;
    in property <string> port_bind_current_binding: "";
    in property <string> port_bind_current_kind: "";
    in property <string> port_bind_node_id: "";
    in property <string> port_bind_port_name: "";
    callback open_hyperparameter_manager();
    callback close_hyperparameter_manager();
    callback open_variable_manager();
    callback close_variable_manager();
    callback open_group_manager();
    callback close_group_manager();
    callback add_hyperparameter(string, string, bool, string, string); // name, data_type, required, description, group
    callback add_graph_variable(string, string, string);          // name, data_type, initial_value
    callback select_hyperparameter_group(string);
    callback create_hyperparameter_group(string);
    callback rename_hyperparameter_group(string, string);
    callback delete_hyperparameter_group(string);
    callback delete_hyperparameter(string);                    // name
    callback delete_graph_variable(string);                   // name
    callback set_hyperparameter_value(string, string);         // name, value
    callback set_graph_variable_initial_value(string, string); // name, value
    callback toggle_hyperparameter_required(string);           // name
    callback port_right_clicked(string, string, float, float); // node_id, port_name, screen x/y
    callback open_port_bind_hyperparameter_dialog();
    callback open_port_bind_variable_dialog();
    callback close_port_bind_menu();
    callback bind_port_hyperparameter(string, string, string); // node_id, port_name, hyperparam_name
    callback bind_port_variable(string, string, string);       // node_id, port_name, variable_name
    callback unbind_port_hyperparameter(string, string);       // node_id, port_name
    callback close_port_bind_dialog();
    callback close_port_variable_bind_dialog();

    // Tool editor
    in property <bool> show_tool_editor_dialog: false;
    in property <string> tool_editor_node_id: "";
    in property <int> tool_editor_selected_index: -1;
    in property <[FunctionPortVm]> tool_editor_shared_inputs;
    in property <[ToolDefinitionVm]> tool_editor_items;
    callback open_tool_editor(string);
    callback close_tool_editor();
    callback save_tool_editor();
    callback tool_editor_select(int);
    callback tool_editor_add_shared_input();
    callback tool_editor_delete_shared_input(int);
    callback tool_editor_set_shared_input_name(int, string);
    callback tool_editor_set_shared_input_type(int, string);
    callback tool_editor_add_tool();
    callback tool_editor_delete_tool(int);
    callback tool_editor_set_tool_name(int, string);
    callback tool_editor_set_tool_description(int, string);
    callback tool_editor_add_param(int);
    callback tool_editor_delete_param(int, int);
    callback tool_editor_set_param_name(int, int, string);
    callback tool_editor_set_param_type(int, int, string);
    callback tool_editor_set_param_description(int, int, string);
    callback tool_editor_add_output(int);
    callback tool_editor_delete_output(int, int);
    callback tool_editor_set_output_name(int, int, string);
    callback tool_editor_set_output_type(int, int, string);
    callback tool_editor_open_subgraph(int);

    // Subgraph navigation
    in property <bool> is_subgraph_page: false;
    in property <string> subgraph_current_label: "";
    callback navigate_subgraph_back();
    callback navigate_subgraph_root();

    // Function editor
    in property <bool> show_function_editor_dialog: false;
    in property <string> function_editor_node_id: "";
    in property <string> function_editor_name: "";
    in property <string> function_editor_description: "";
    in property <[FunctionPortVm]> function_editor_inputs;
    in property <[FunctionPortVm]> function_editor_outputs;
    in property <[string]> function_editor_data_types;
    callback open_function_editor(string);
    callback close_function_editor();
    callback save_function_editor();
    callback function_editor_set_name(string);
    callback function_editor_set_description(string);
    callback function_editor_add_input();
    callback function_editor_delete_input(int);
    callback function_editor_set_input_name(int, string);
    callback function_editor_set_input_type(int, string);
    callback function_editor_add_output();
    callback function_editor_delete_output(int);
    callback function_editor_set_output_name(int, string);
    callback function_editor_set_output_type(int, string);

    // JSON extract editor
    in property <bool> show_json_extract_editor_dialog: false;
    in property <string> json_extract_editor_node_id: "";
    in property <int> json_extract_editor_selected_index: -1;
    in property <[JsonExtractFieldVm]> json_extract_editor_items;
    callback open_json_extract_editor(string);
    callback close_json_extract_editor();
    callback save_json_extract_editor();
    callback json_extract_editor_select(int);
    callback json_extract_editor_add_field();
    callback json_extract_editor_delete_field(int);
    callback json_extract_editor_set_field_name(int, string);
    callback json_extract_editor_set_field_type(int, string);

    // Format string editor
    in property <bool> show_format_string_editor: false;
    in property <string> format_string_editor_node_id: "";
    in-out property <string> format_string_editor_template: "";
    in property <[string]> format_string_editor_variables;
    in property <[string]> format_string_editor_suggestions;
    in property <bool> format_string_show_autocomplete: false;
    in property <int> format_string_autocomplete_selected_index: -1;
    callback open_format_string_editor(string);
    callback close_format_string_editor();
    callback save_format_string_editor();
    callback format_string_text_changed(string, int);
    callback format_string_autocomplete_select(string);
    callback format_string_autocomplete_navigate(int);
    callback format_string_autocomplete_accept();

    // Log overlay
    in-out property <[LogEntryVm]> log_entries;
    in-out property <float> log_overlay_opacity: 0.0;
    animate log_overlay_opacity { duration: 500ms; easing: ease; }

    // Log history dialog
    in property <[LogEntryVm]> log_history;
    in-out property <bool> show_log_history: false;
    callback open_log_history();
    callback close_log_history();
    in property <bool> graph_shortcuts_enabled:
        !show_node_selector
        && !show_error_dialog
        && !show_validation_fix_dialog
        && !show_graph_context_menu
        && !menu_open
        && !show_save_confirm
        && !show_running_confirm
        && !show_overwrite_confirm
        && !show_node_help_dialog
        && !show_hyperparameter_manager
        && !show_variable_manager
        && !show_group_manager
        && !show_port_bind_menu
        && !show_port_bind_dialog
        && !show_port_variable_bind_dialog
        && !show_tool_editor_dialog
        && !show_function_editor_dialog
        && !show_format_string_editor
        && !show_json_extract_editor_dialog
        && !show_log_history;

    title: "Zihuan Node Graph Viewer";
    preferred-width: 1200px;
    preferred-height: 800px;
    min-width: 800px;
    min-height: 600px;

    forward-focus: key-handler;

    key-handler := FocusScope {
        width: 100%;
        height: 100%;

        capture-key-pressed(event) => {
            if (event.modifiers.control || event.modifiers.meta) {
                if (event.modifiers.shift && (event.text == "s" || event.text == "S")) {
                    root.save_json_as();
                    return accept;
                }
                if (event.text == "o" || event.text == "O") {
                    root.open_json();
                    return accept;
                }
                if (event.text == "s" || event.text == "S") {
                    root.save_json();
                    return accept;
                }
                if (event.text == "t" || event.text == "T") {
                    root.new_tab();
                    return accept;
                }
                if (event.text == "w" || event.text == "W") {
                    root.close_tab();
                    return accept;
                }
                if (root.graph_shortcuts_enabled && (event.text == "c" || event.text == "C")) {
                    root.copy_selected_nodes();
                    return accept;
                }
                if (root.graph_shortcuts_enabled && (event.text == "v" || event.text == "V")) {
                    root.paste_nodes_at_context();
                    return accept;
                }
            }
            return reject;
        }

    VerticalLayout {
        // Menu bar area
        if root.show_in_window_menu : Rectangle {
            height: 24px;
            background: AppTheme.menu-bar-bg;

            HorizontalLayout {
                padding: 0px;
                spacing: 0px;
                alignment: start;

                // Windows-style menu bar item
                MenuBarItem {
                    text: "文件";
                    is_open: root.menu_open;
                    clicked => { root.menu_open = !root.menu_open; }
                }
            }

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: parent.width;
                background: AppTheme.menu-bar-border;
            }
        }

        Rectangle {
            height: 32px;
            background: AppTheme.surface;

            Flickable {
                height: 32px;
                viewport-height: 32px;
                width: parent.width;
                viewport-width: tabs-layout.preferred-width;

                tabs-layout := HorizontalLayout {
                    spacing: 0px;
                    alignment: start;

                    for tab[i] in root.graph_tabs: TabItem {
                        text: tab;
                        is_active: i == root.active_tab_index;
                        clicked => { root.select_tab(i); }
                    }
                }
            }

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: parent.width;
                background: AppTheme.border;
            }
        }

        if root.is_subgraph_page: Rectangle {
            height: 34px;
            background: AppTheme.node-bg;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;
                alignment: start;

                // "返回" clickable text
                ta-back := TouchArea {
                    height: 24px;
                    width: back-label.preferred-width + 4px;
                    mouse-cursor: pointer;
                    clicked => { root.navigate_subgraph_back(); }

                    back-label := CjkText {
                        text: "返回";
                        color: ta-back.has-hover ? AppTheme.primary : AppTheme.text-secondary;
                        vertical-alignment: center;
                        font-size: 13px;
                        font-weight: 600;
                    }
                }

                CjkText {
                    text: "·";
                    color: AppTheme.text-secondary;
                    vertical-alignment: center;
                    font-size: 13px;
                }

                // "主图" clickable breadcrumb link
                ta-root := TouchArea {
                    height: 24px;
                    width: root-label.preferred-width + 4px;
                    mouse-cursor: pointer;
                    clicked => { root.navigate_subgraph_root(); }

                    root-label := CjkText {
                        text: "主图";
                        color: ta-root.has-hover ? AppTheme.primary : AppTheme.text-secondary;
                        vertical-alignment: center;
                        font-size: 13px;
                        font-weight: 600;
                    }
                }

                CjkText {
                    text: "/";
                    color: AppTheme.text-secondary;
                    vertical-alignment: center;
                    font-size: 13px;
                }

                CjkText {
                    text: root.subgraph_current_label;
                    color: AppTheme.text-primary;
                    vertical-alignment: center;
                    font-size: 13px;
                    font-weight: 700;
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: parent.width;
                background: AppTheme.border;
            }
        }

        canvas_container := Rectangle {
            vertical-stretch: 1;
            clip: true;

            GraphCanvas {
                width: 100%;
                height: 100%;
                nodes: root.nodes;
                edges: root.edges;
                edge_segments: root.edge_segments;
                edge_corners: root.edge_corners;
                edge_labels: root.edge_labels;
                grid_lines: root.grid_lines;
                grid_size: root.grid_size;
                edge_thickness: root.edge_thickness;
                drag_line_visible: root.drag_line_visible;
                drag_line_from_x: root.drag_line_from_x;
                drag_line_from_y: root.drag_line_from_y;
                drag_line_to_x: root.drag_line_to_x;
                drag_line_to_y: root.drag_line_to_y;
                dragging: root.dragging;
                drag_from_node_id: root.drag_from_node_id;
                drag_from_port: root.drag_from_port;
                drag_from_is_input: root.drag_from_is_input;
                canvas_pan_x <=> root.canvas_pan_x;
                canvas_pan_y <=> root.canvas_pan_y;
                canvas_zoom <=> root.canvas_zoom;
                box_selection_visible: root.box_selection_visible;
                box_selection_x: root.box_selection_x;
                box_selection_y: root.box_selection_y;
                box_selection_width: root.box_selection_width;
                box_selection_height: root.box_selection_height;
                is_graph_running: root.is_graph_running;
                
                node_pointer_down(node_id, shift_pressed) => {
                    key-handler.focus();
                    root.node_pointer_down(node_id, shift_pressed);
                }

                node_moved(node_id, x, y) => {
                    root.node_moved(node_id, x, y);
                }

                node_move_finished(node_id, x, y) => {
                    root.node_move_finished(node_id, x, y);
                }
                
                port_clicked(node_id, port_name, is_input) => {
                    key-handler.focus();
                    root.port_clicked(node_id, port_name, is_input);
                }
                pointer_moved(x, y) => {
                    root.pointer_moved(x, y);
                }
                cancel_connect() => {
                    root.cancel_connect();
                }
                
                node_clicked(node_id, shift_pressed) => {
                    key-handler.focus();
                    root.node_clicked(node_id, shift_pressed);
                }

                node_right_clicked(node_id, x, y) => {
                    key-handler.focus();
                    root.node_right_clicked(node_id, x, y);
                }
                
                edge_clicked(from_node, from_port, to_node, to_port) => {
                    key-handler.focus();
                    root.edge_clicked(from_node, from_port, to_node, to_port);
                }
                
                canvas_clicked() => {
                    key-handler.focus();
                    root.canvas_clicked();
                }

                canvas_right_clicked(x, y, canvas_x, canvas_y) => {
                    key-handler.focus();
                    root.canvas_right_clicked(x, y, canvas_x, canvas_y);
                }
                
                box_selection_start(x, y) => {
                    key-handler.focus();
                    root.box_selection_start(x, y);
                }
                
                box_selection_update(x, y) => {
                    root.box_selection_update(x, y);
                }
                
                box_selection_end() => {
                    root.box_selection_end();
                }

                inline_port_text_changed(node_id, port_name, value) => {
                    root.inline_port_text_changed(node_id, port_name, value);
                }

                inline_port_bool_changed(node_id, port_name, value) => {
                    root.inline_port_bool_changed(node_id, port_name, value);
                }

                message_list_add(node_id) => {
                    root.message_list_add(node_id);
                }

                message_list_insert(node_id, index) => {
                    root.message_list_insert(node_id, index);
                }

                message_list_delete(node_id, index) => {
                    root.message_list_delete(node_id, index);
                }

                message_list_move_up(node_id, index) => {
                    root.message_list_move_up(node_id, index);
                }

                message_list_move_down(node_id, index) => {
                    root.message_list_move_down(node_id, index);
                }

                message_list_cycle_role(node_id, index) => {
                    root.message_list_cycle_role(node_id, index);
                }

                message_list_set_content(node_id, index, value) => {
                    root.message_list_set_content(node_id, index, value);
                }

                qq_message_list_add(node_id) => {
                    root.qq_message_list_add(node_id);
                }

                qq_message_list_insert(node_id, index) => {
                    root.qq_message_list_insert(node_id, index);
                }

                qq_message_list_cycle_type(node_id, index) => {
                    root.qq_message_list_cycle_type(node_id, index);
                }

                qq_message_list_set_content(node_id, index, value) => {
                    root.qq_message_list_set_content(node_id, index, value);
                }

                node_resized(node_id, width, height) => {
                    root.node_resized(node_id, width, height);
                }

                node_resize_finished(node_id, width, height) => {
                    root.node_resize_finished(node_id, width, height);
                }

                show_node_help(node_id, node_type) => {
                    root.show_node_help(node_id, node_type);
                }

                port_right_clicked(node_id, port_name, x, y) => {
                    root.port_right_clicked(node_id, port_name, x, y);
                }

                edit_tools_clicked(node_id) => {
                    root.edit_tools_clicked(node_id);
                }

                edit_function_clicked(node_id) => {
                    root.edit_function_clicked(node_id);
                }

                enter_function_subgraph_clicked(node_id) => {
                    root.enter_function_subgraph_clicked(node_id);
                }

                edit_format_string_clicked(node_id) => {
                    root.edit_format_string_clicked(node_id);
                }

                edit_json_extract_clicked(node_id) => {
                    root.edit_json_extract_clicked(node_id);
                }

                set_variable_node_selected(node_id, variable_name) => {
                    root.set_variable_node_selected(node_id, variable_name);
                }
            }

            // Log overlay — bottom-left of canvas
            LogOverlay {
                x: 8px;
                y: parent.height - self.preferred-height - 50px;
                width: 420px;
                opacity: root.log_overlay_opacity;
                entries: root.log_entries;
            }

            // Buttons Overlay
            Rectangle {
                x: parent.width - self.width - 20px;
                y: parent.height - self.height - 20px;
                width: buttons-layout.preferred-width;
                height: buttons-layout.preferred-height;
                
                buttons-layout := HorizontalLayout {
                    spacing: 12px;

                    CjkButton {
                        text: "日志";
                        clicked => { root.open_log_history(); }
                    }

                    CjkButton {
                        text: "超参数";
                        clicked => { root.open_hyperparameter_manager(); }
                    }

                    CjkButton {
                        text: "变量";
                        clicked => { root.open_variable_manager(); }
                    }

                    CjkButton {
                        text: "自动排布";
                        clicked => { root.auto_layout_graph(); }
                    }

                    CjkButton {
                        text: "新增节点";
                        clicked => { root.show_node_type_menu(); }
                    }

                    if !root.is_graph_running && !root.is_subgraph_page: CjkRunButton {
                        text: "运行节点图";
                        clicked => { root.run_graph(); }
                    }

                    if root.is_graph_running && !root.is_subgraph_page: CjkDeleteButton {
                        text: "停止运行";
                        clicked => { root.stop_graph(); }
                    }

                    if root.selected_node_count > 0 || root.selected_edge_from_node != "": CjkDeleteButton {
                        text: root.selected_node_count > 1 ? "删除选中节点" : "删除选中";
                        clicked => { root.delete_selected(); }
                    }
                }
            }

            // Port hint - centered at bottom
            if root.show_port_hint: Rectangle {
                width: 300px;
                height: 30px;
                background: #00000060;
                border-radius: 4px;
                border-width: 1px;
                border-color: #4a4a4a;
                // Position relative to the container rectangle
                x: (parent.width - self.width) / 2;
                y: parent.height - self.height - 50px;

                CjkText {
                    text: root.port_hint_text;
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: 12px;
                    width: 100%;
                    height: 100%;
                }
            }

            if root.show_graph_context_menu: Rectangle {
                width: parent.width;
                height: parent.height;
                background: #00000000;

                TouchArea {
                    clicked => { root.hide_graph_context_menu(); }
                }

                Rectangle {
                    property <int> item-count:
                        root.graph_context_menu_mode == "canvas"
                            ? (root.graph_context_menu_can_paste ? 2 : 1)
                            : (root.graph_context_menu_mode == "selection" ? 3 : 0);
                    x: max(4px, min(root.graph_context_menu_x * 1px, parent.width - self.width - 4px));
                    y: max(4px, min(root.graph_context_menu_y * 1px, parent.height - self.height - 4px));
                    width: 180px;
                    height: (item-count * 28px) + (max(item-count - 1, 0) * 2px) + 12px;
                    background: AppTheme.menu-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: AppTheme.menu-border;

                    TouchArea {}

                    context-menu-items := VerticalBox {
                        padding: 6px;
                        spacing: 2px;
                        alignment: start;

                        if root.graph_context_menu_mode == "canvas": MenuItemRow {
                            title: "新建节点";
                            shortcut: "";
                            clicked => { root.context_menu_new_node(); }
                        }

                        if root.graph_context_menu_mode == "canvas" && root.graph_context_menu_can_paste: MenuItemRow {
                            title: "粘贴节点";
                            shortcut: "";
                            clicked => { root.paste_nodes_at_context(); }
                        }

                        if root.graph_context_menu_mode == "selection": MenuItemRow {
                            title: "复制节点";
                            shortcut: "";
                            clicked => { root.copy_selected_nodes(); }
                        }

                        if root.graph_context_menu_mode == "selection": MenuItemRow {
                            title: "转换为函数子图";
                            shortcut: "";
                            clicked => { root.convert_selection_to_function_subgraph(); }
                        }

                        if root.graph_context_menu_mode == "selection": MenuItemRow {
                            title: "删除节点";
                            shortcut: "";
                            clicked => { root.delete_selected(); }
                        }
                    }
                }
            }
        }
    }


    if root.show_node_selector: NodeSelector {
        node_types: root.available_node_types;
        categories: root.node_categories;
        close => { root.hide_node_type_menu(); }
        add_node(type_id) => { 
            root.add_node(type_id);
            root.hide_node_type_menu(); 
        }
        filter(text, category) => { root.filter_nodes(text, category); }
    }

    if root.show_error_dialog: ErrorDialog {
        error_message: root.error_dialog_message;
        close => { root.hide_error(); }
    }

    if root.show_in_window_menu && root.menu_open: Rectangle {
        x: 0px;
        y: 24px;
        width: parent.width;
        height: parent.height - 24px;
        background: #00000000;

        TouchArea {
            clicked => { root.menu_open = false; }
        }

        Rectangle {
            x: 6px;
            y: 0px;
            width: 260px;
            height: 168px;
            background: AppTheme.menu-bg;
            border-radius: 4px;
            border-width: 1px;
            border-color: AppTheme.menu-border;

            TouchArea {} // Block clicks

            VerticalBox {
                padding: 6px;
                spacing: 2px;

                MenuItemRow {
                    title: "打开...";
                    shortcut: "Ctrl+O";
                    clicked => { root.open_json(); root.menu_open = false; }
                }

                MenuItemRow {
                    title: "保存";
                    shortcut: "Ctrl+S";
                    clicked => { root.save_json(); root.menu_open = false; }
                }

                MenuItemRow {
                    title: "另存为...";
                    shortcut: "Ctrl+Shift+S";
                    clicked => { root.save_json_as(); root.menu_open = false; }
                }

                Rectangle {
                    height: 1px;
                    background: AppTheme.menu-separator;
                    width: parent.width - 2px;
                    x: 1px;
                }

                MenuItemRow {
                    title: "新建标签页";
                    shortcut: "Ctrl+T";
                    clicked => { root.new_tab(); root.menu_open = false; }
                }

                MenuItemRow {
                    title: "关闭标签页";
                    shortcut: "Ctrl+W";
                    clicked => { root.close_tab(); root.menu_open = false; }
                }
            }
        }
    }

    if root.show_save_confirm: SaveConfirmDialog {
        message: root.save_confirm_message;
        save => { root.save_confirm_save(); }
        discard => { root.save_confirm_discard(); }
        cancel => { root.save_confirm_cancel(); }
    }

    if root.show_running_confirm: RunningConfirmDialog {
        message: root.running_confirm_message;
        confirm_close => { root.running_confirm_close(); }
        cancel => { root.running_confirm_cancel(); }
    }

    if root.show_overwrite_confirm: OverwriteConfirmDialog {
        message: root.overwrite_confirm_message;
        overwrite => { root.overwrite_confirm_overwrite(); }
        cancel => { root.overwrite_confirm_cancel(); }
    }

    if root.show_node_help_dialog: NodeHelpDialog {
        node_data: root.node_help_data;
        close => { root.hide_node_help(); }
    }

    if root.show_hyperparameter_manager: HyperParameterManagerDialog {
        hyperparameters: root.hyperparameters;
        groups: root.hyperparameter_groups;
        current_group <=> root.selected_hyperparameter_group;
        open_group_manager() => { root.open_group_manager(); }
        add(name, data_type, required, description, group) => {
            root.add_hyperparameter(name, data_type, required, description, group);
        }
        select_group(name) => { root.select_hyperparameter_group(name); }
        delete(name) => { root.delete_hyperparameter(name); }
        set_value(name, value) => { root.set_hyperparameter_value(name, value); }
        toggle_required(name) => { root.toggle_hyperparameter_required(name); }
        close => { root.close_hyperparameter_manager(); }
    }

    if root.show_variable_manager: VariableManagerDialog {
        variables: root.graph_variables;
        add(name, data_type, initial_value) => {
            root.add_graph_variable(name, data_type, initial_value);
        }
        delete(name) => { root.delete_graph_variable(name); }
        set_initial_value(name, value) => { root.set_graph_variable_initial_value(name, value); }
        close => { root.close_variable_manager(); }
    }

    if root.show_group_manager: GroupManagerDialog {
        groups: root.hyperparameter_groups;
        current_group <=> root.selected_hyperparameter_group;
        select_group(name) => { root.select_hyperparameter_group(name); }
        create_group(name) => { root.create_hyperparameter_group(name); }
        rename_group(old_name, new_name) => { root.rename_hyperparameter_group(old_name, new_name); }
        delete_group(name) => { root.delete_hyperparameter_group(name); }
        close => { root.close_group_manager(); }
    }

    if root.show_port_bind_menu: Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000000;

        TouchArea {
            clicked => { root.close_port_bind_menu(); }
        }

        Rectangle {
            x: max(4px, min(root.port_bind_menu_x * 1px, parent.width - self.width - 4px));
            y: max(4px, min(root.port_bind_menu_y * 1px, parent.height - self.height - 4px));
            width: 180px;
            height: 70px;
            background: AppTheme.menu-bg;
            border-radius: 4px;
            border-width: 1px;
            border-color: AppTheme.menu-border;

            TouchArea {}

            VerticalBox {
                padding: 6px;
                spacing: 2px;

                MenuItemRow {
                    title: "绑定变量";
                    shortcut: "";
                    clicked => { root.open_port_bind_variable_dialog(); }
                }

                MenuItemRow {
                    title: "绑定超参数";
                    shortcut: "";
                    clicked => { root.open_port_bind_hyperparameter_dialog(); }
                }
            }
        }
    }

    if root.show_port_bind_dialog: PortBindHyperparamDialog {
        compatible_params: root.port_bind_compatible_params;
        current_binding: root.port_bind_current_binding;
        port_name: root.port_bind_port_name;
        bind(name) => {
            root.bind_port_hyperparameter(root.port_bind_node_id, root.port_bind_port_name, name);
        }
        clear_binding() => {
            root.unbind_port_hyperparameter(root.port_bind_node_id, root.port_bind_port_name);
        }
        close => { root.close_port_bind_dialog(); }
    }

    if root.show_port_variable_bind_dialog: PortBindVariableDialog {
        compatible_variables: root.port_bind_compatible_variables;
        current_binding: root.port_bind_current_binding;
        port_name: root.port_bind_port_name;
        bind(name) => {
            root.bind_port_variable(root.port_bind_node_id, root.port_bind_port_name, name);
        }
        clear_binding() => {
            root.unbind_port_hyperparameter(root.port_bind_node_id, root.port_bind_port_name);
        }
        close => { root.close_port_variable_bind_dialog(); }
    }

    if root.show_tool_editor_dialog: ToolEditorDialog {
        shared-inputs: root.tool_editor_shared_inputs;
        tools: root.tool_editor_items;
        selected_tool_index: root.tool_editor_selected_index;
        select_tool(index) => { root.tool_editor_select(index); }
        add_shared_input() => { root.tool_editor_add_shared_input(); }
        delete_shared_input(index) => { root.tool_editor_delete_shared_input(index); }
        set_shared_input_name(index, value) => { root.tool_editor_set_shared_input_name(index, value); }
        set_shared_input_type(index, value) => { root.tool_editor_set_shared_input_type(index, value); }
        add_tool() => { root.tool_editor_add_tool(); }
        delete_tool(index) => { root.tool_editor_delete_tool(index); }
        set_tool_name(index, value) => { root.tool_editor_set_tool_name(index, value); }
        set_tool_description(index, value) => { root.tool_editor_set_tool_description(index, value); }
        add_param(index) => { root.tool_editor_add_param(index); }
        delete_param(tool_index, param_index) => { root.tool_editor_delete_param(tool_index, param_index); }
        set_param_name(tool_index, param_index, value) => { root.tool_editor_set_param_name(tool_index, param_index, value); }
        set_param_type(tool_index, param_index, value) => { root.tool_editor_set_param_type(tool_index, param_index, value); }
        set_param_description(tool_index, param_index, value) => { root.tool_editor_set_param_description(tool_index, param_index, value); }
        add_output(tool_index) => { root.tool_editor_add_output(tool_index); }
        delete_output(tool_index, output_index) => { root.tool_editor_delete_output(tool_index, output_index); }
        set_output_name(tool_index, output_index, value) => { root.tool_editor_set_output_name(tool_index, output_index, value); }
        set_output_type(tool_index, output_index, value) => { root.tool_editor_set_output_type(tool_index, output_index, value); }
        open_tool_subgraph(tool_index) => { root.tool_editor_open_subgraph(tool_index); }
        save => { root.save_tool_editor(); }
        close => { root.close_tool_editor(); }
    }

    if root.show_function_editor_dialog: FunctionEditorDialog {
        function_name: root.function_editor_name;
        function_description: root.function_editor_description;
        inputs: root.function_editor_inputs;
        outputs: root.function_editor_outputs;
        data_types: root.function_editor_data_types;
        set_function_name(value) => { root.function_editor_set_name(value); }
        set_function_description(value) => { root.function_editor_set_description(value); }
        add_input() => { root.function_editor_add_input(); }
        delete_input(index) => { root.function_editor_delete_input(index); }
        set_input_name(index, value) => { root.function_editor_set_input_name(index, value); }
        set_input_type(index, value) => { root.function_editor_set_input_type(index, value); }
        add_output() => { root.function_editor_add_output(); }
        delete_output(index) => { root.function_editor_delete_output(index); }
        set_output_name(index, value) => { root.function_editor_set_output_name(index, value); }
        set_output_type(index, value) => { root.function_editor_set_output_type(index, value); }
        save => { root.save_function_editor(); }
        close => { root.close_function_editor(); }
    }

    if root.show_format_string_editor: FormatStringEditorDialog {
        template_text <=> root.format_string_editor_template;
        variables: root.format_string_editor_variables;
        autocomplete_suggestions: root.format_string_editor_suggestions;
        show_autocomplete: root.format_string_show_autocomplete;
        autocomplete_selected_index: root.format_string_autocomplete_selected_index;
        text_changed(text, cursor_offset) => { root.format_string_text_changed(text, cursor_offset); }
        autocomplete_select(s) => { root.format_string_autocomplete_select(s); }
        autocomplete_navigate(delta) => { root.format_string_autocomplete_navigate(delta); }
        autocomplete_accept() => { root.format_string_autocomplete_accept(); }
        save => { root.save_format_string_editor(); }
        cancel => { root.close_format_string_editor(); }
    }

    if root.show_json_extract_editor_dialog: JsonExtractEditorDialog {
        fields: root.json_extract_editor_items;
        selected_field_index: root.json_extract_editor_selected_index;
        select_field(index) => { root.json_extract_editor_select(index); }
        add_field() => { root.json_extract_editor_add_field(); }
        delete_field(index) => { root.json_extract_editor_delete_field(index); }
        set_field_name(index, value) => { root.json_extract_editor_set_field_name(index, value); }
        set_field_type(index, value) => { root.json_extract_editor_set_field_type(index, value); }
        save => { root.save_json_extract_editor(); }
        close => { root.close_json_extract_editor(); }
    }

    if root.show_log_history: LogHistoryDialog {
        entries: root.log_history;
        close => { root.close_log_history(); }
    }

    if root.show_validation_fix_dialog: ValidationFixDialog {
        issues: root.validation_issues;
        confirm => { root.validation_fix_confirm(); }
        cancel => { root.validation_fix_cancel(); }
    }
    } // end FocusScope key-handler
}
